<?php

/**
 * @file
 * CRM Navigation module hooks.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;

/**
 * Implements hook_form_alter().
 */
function crm_navigation_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Add navigation to node forms (add/edit pages)
  if (preg_match('/^node_(contact|deal|activity|organization)_(form|edit_form)$/', $form_id, $matches)) {
    $entity_type = $matches[1];
    
    // Add back button at the top
    $form['back_button'] = [
      '#type' => 'container',
      '#attributes' => ['class' => ['crm-form-back-button']],
      '#weight' => -100,
    ];
    
    $back_label = t('← Back to @type list', ['@type' => ucfirst($entity_type) . 's']);
    $back_url = \Drupal::service('crm_navigation.helper')->getContextBackUrl($entity_type);
    
    $form['back_button']['link'] = [
      '#type' => 'link',
      '#title' => $back_label,
      '#url' => $back_url,
      '#attributes' => [
        'class' => ['button', 'button--secondary', 'crm-back-link'],
      ],
    ];

    // Add quick navigation below title
    $form['quick_nav'] = [
      '#type' => 'container',
      '#weight' => -99,
      'nav' => \Drupal::service('crm_navigation.helper')->getNavigationBar(),
    ];
  }

  // Add cancel button to forms that don't have one
  if (isset($form['actions']['submit']) && !isset($form['actions']['cancel'])) {
    // Determine where to go back
    $current_path = \Drupal::service('path.current')->getPath();
    
    if (strpos($form_id, 'contact') !== FALSE) {
      $cancel_route = 'crm.my_contacts';
    }
    elseif (strpos($form_id, 'deal') !== FALSE) {
      $cancel_route = 'crm.my_deals';
    }
    elseif (strpos($form_id, 'activity') !== FALSE) {
      $cancel_route = 'crm.my_activities';
    }
    elseif (strpos($form_id, 'organization') !== FALSE) {
      $cancel_route = 'crm.all_organizations';
    }
    else {
      $cancel_route = 'crm_dashboard.dashboard';
    }

    try {
      $form['actions']['cancel'] = [
        '#type' => 'link',
        '#title' => t('Cancel'),
        '#url' => Url::fromRoute($cancel_route),
        '#attributes' => [
          'class' => ['button', 'button--secondary'],
        ],
        '#weight' => 100,
      ];
    }
    catch (\Exception $e) {
      // Route doesn't exist, skip
    }
  }
}

/**
 * Implements hook_preprocess_page().
 */
function crm_navigation_preprocess_page(&$variables) {
  $current_route = \Drupal::routeMatch()->getRouteName();
  
  // Attach navigation CSS to all CRM pages
  if (preg_match('/^(crm_|view\.(my_|all_))/', $current_route)) {
    $variables['#attached']['library'][] = 'crm_navigation/navigation_styles';
  }
}

/**
 * Implements hook_library_info_build().
 */
function crm_navigation_library_info_build() {
  return [
    'navigation_styles' => [
      'css' => [
        'theme' => [
          'css/navigation.css' => [],
        ],
      ],
    ],
  ];
}



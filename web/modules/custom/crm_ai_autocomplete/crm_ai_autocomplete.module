<?php

/**
 * @file
 * CRM AI AutoComplete module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_form_alter().
 *
 * Adds AI Complete button to entity forms and generate button to views.
 */
function crm_ai_autocomplete_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $account = \Drupal::currentUser();

  // Check permission.
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  // Add AI to entity forms
  $supported_forms = [
    'node_contact_form',
    'node_contact_edit_form',
    'node_deal_form',
    'node_deal_edit_form',
    'node_organization_form',
    'node_organization_edit_form',
    'node_activity_form',
    'node_activity_edit_form',
  ];

  if (in_array($form_id, $supported_forms)) {
    // Attach library.
    $form['#attached']['library'][] = 'crm_ai_autocomplete/ai-autocomplete';

    // Add AI Complete button to form actions.
    if (!isset($form['actions'])) {
      $form['actions'] = ['#type' => 'actions'];
    }

    $form['actions']['ai_complete'] = [
      '#type' => 'button',
      '#value' => '✨ ' . t('AI Complete'),
      '#name' => 'ai_complete_button',
      '#attributes' => [
        'class' => ['btn-ai-complete', 'button', 'button--primary'],
        'data-form-id' => $form_id,
      ],
      '#submit' => [],
      '#weight' => -5,
    ];

    // Add Drupal settings for JavaScript.
    $form['#attached']['drupalSettings']['crm_ai_autocomplete'] = [
      'endpoint' => '/api/crm/ai/autocomplete',
    ];
  }

  // Add button to views exposed forms is now handled by views header
}

/**
 * Implements hook_page_attachments_alter().
 *
 * Attach JavaScript to initialize the button handler.
 */
function crm_ai_autocomplete_page_attachments_alter(array &$attachments) {
  $account = \Drupal::currentUser();

  // Check permissions.
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  // Attach the AI generate button JavaScript library.
  $attachments['#attached']['library'][] = 'crm_ai_autocomplete/ai-generate-button';
}

/**
 * Implements hook_form_views_exposed_form_alter().
 *
 * Injects Add and Generate buttons into the exposed filter toolbar so they
 * appear in the same row as the Search button (right-aligned). This follows
 * the standard CRM pattern: filters on the left, action buttons on the right.
 */
function crm_ai_autocomplete_form_views_exposed_form_alter(&$form, FormStateInterface $form_state) {
  $account = \Drupal::currentUser();
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  $view = $form_state->get('view');
  if (!$view) {
    return;
  }

  $view_map = [
    'all_contacts'      => ['/crm/add/contact',      'Add Contact',      'contact'],
    'my_contacts'       => ['/crm/add/contact',      'Add Contact',      'contact'],
    'all_deals'         => ['/crm/add/deal',          'Add Deal',         'deal'],
    'all_activities'    => ['/crm/add/activity',     'Add Activity',     'activity'],
    'all_organizations' => ['/crm/add/organization', 'Add Organization', 'organization'],
  ];

  if (!isset($view_map[$view->id()])) {
    return;
  }

  [$add_url, $add_label, $entity_type] = $view_map[$view->id()];

  if (!isset($form['actions'])) {
    $form['actions'] = ['#type' => 'actions'];
  }

  $icon = 'width:16px;height:16px;vertical-align:middle;margin-right:5px;';

  // "Add Contact" / "Add Deal" — rendered as <button> so height/padding
  // matches Search and Generate data exactly (avoids <a> vs <input> sizing gap).
  $form['actions']['crm_add'] = [
    '#markup' => Markup::create(
      '<button type="button" class="button crm-add-btn" onclick="window.location=\'' . $add_url . '\'">' .
      '<i data-lucide="plus" style="' . $icon . '"></i>' . $add_label . '</button>'
    ),
    '#weight' => 10,
  ];

  // "Generate data" — JS-driven, must be type=button to avoid form submit.
  $form['actions']['crm_generate'] = [
    '#markup' => Markup::create(
      '<button type="button" id="crm-ai-generate-btn" data-entity-type="' . $entity_type . '" class="button crm-generate-btn">' .
      '<i data-lucide="sparkles" style="' . $icon . '"></i>Generate data</button>'
    ),
    '#weight' => 11,
  ];
}



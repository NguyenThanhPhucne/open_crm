<?php

/**
 * @file
 * CRM AI AutoComplete module.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_form_alter().
 *
 * Adds AI Complete button to entity forms and generate button to views.
 */
function crm_ai_autocomplete_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $account = \Drupal::currentUser();

  // Check permission.
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  // Add AI to entity forms
  $supported_forms = [
    'node_contact_form',
    'node_contact_edit_form',
    'node_deal_form',
    'node_deal_edit_form',
    'node_organization_form',
    'node_organization_edit_form',
    'node_activity_form',
    'node_activity_edit_form',
  ];

  if (in_array($form_id, $supported_forms)) {
    // Attach library.
    $form['#attached']['library'][] = 'crm_ai_autocomplete/ai-autocomplete';

    // Add AI Complete button to form actions.
    if (!isset($form['actions'])) {
      $form['actions'] = ['#type' => 'actions'];
    }

    $form['actions']['ai_complete'] = [
      '#type' => 'button',
      '#value' => '✨ ' . t('AI Complete'),
      '#name' => 'ai_complete_button',
      '#attributes' => [
        'class' => ['btn-ai-complete', 'button', 'button--primary'],
        'data-form-id' => $form_id,
      ],
      '#submit' => [],
      '#weight' => -5,
    ];

    // Add Drupal settings for JavaScript.
    $form['#attached']['drupalSettings']['crm_ai_autocomplete'] = [
      'endpoint' => '/api/crm/ai/autocomplete',
    ];
  }

  // Add button to views exposed forms is now handled by views header
}

/**
 * Implements hook_page_attachments_alter().
 *
 * Attach JavaScript to initialize the button handler.
 */
function crm_ai_autocomplete_page_attachments_alter(array &$attachments) {
  $account = \Drupal::currentUser();

  // Check permissions.
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  // Attach the AI generate button JavaScript library.
  $attachments['#attached']['library'][] = 'crm_ai_autocomplete/ai-generate-button';
}

/**
 * Implements hook_preprocess_views_view().
 *
 * Add buttons to view header.
 */
function crm_ai_autocomplete_preprocess_views_view(&$variables) {
  $account = \Drupal::currentUser();

  // Check permissions.
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  $view = $variables['view'];
  
  // Only for specific views and displays
  if (($view->id() === 'all_contacts' || $view->id() === 'my_contacts') && 
      ($view->current_display === 'page_1')) {
    
    // Create header HTML markup with professional icons
    $html = '<div style="text-align: right; margin-bottom: 20px;">' .
            '<a href="/node/add/contact" class="button button--action button--primary">' .
            '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">' .
            '<path d="M12 5v14M5 12h14"></path></svg> Add Contact' .
            '</a>' .
            '<button type="button" id="crm-ai-generate-btn" class="button button--action button--primary" style="margin-left: 10px;">' .
            '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align: middle; margin-right: 6px;">' .
            '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>' .
            'Generate data' .
            '</button>' .
            '</div>';
    
    // Add markup to the view  
    $variables['view_array']['#prefix'] = Markup::create($html);
  }
}



/**
 * Helper function: Check if two users are in the same team.
 * 
 * @param int $uid1
 *   First user ID.
 * @param int $uid2
 *   Second user ID.
 * 
 * @return bool
 *   TRUE if same team, FALSE otherwise.
 */
function _crm_check_same_team($uid1, $uid2) {
  $team1 = _crm_get_user_team($uid1);
  $team2 = _crm_get_user_team($uid2);
  
  // If either user has no team, return FALSE (no team-based access).
  if (empty($team1) || empty($team2)) {
    return FALSE;
  }
  
  return ($team1 === $team2);
}

/**
 * Helper function: Get user's team ID.
 * 
 * @param int $uid
 *   User ID.
 * 
 * @return int|null
 *   Team taxonomy term ID or NULL.
 */
function _crm_get_user_team($uid) {
  $user = \Drupal::entityTypeManager()->getStorage('user')->load($uid);
  
  if ($user && $user->hasField('field_team') && !$user->get('field_team')->isEmpty()) {
    return $user->get('field_team')->target_id;
  }
  
  return NULL;
}

/**
 * Helper function: Get entity owner's team ID.
 * 
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity (node).
 * 
 * @return int|null
 *   Team taxonomy term ID or NULL.
 */
function _crm_get_entity_owner_team(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->hasField('uid')) {
    $owner = $entity->get('uid')->entity;
    
    if ($owner) {
      return _crm_get_user_team($owner->id());
    }
  }
  
  return NULL;
}

/**
 * Implements hook_help().
 */
function crm_help($route_name, \Drupal\Core\Routing\RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.crm':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('CRM Core module provides unified access control for Open CRM system.') . '</p>';
      $output .= '<h3>' . t('Access Control Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Owner-based access control (field_owner, field_assigned_to, field_assigned_staff)') . '</li>';
      $output .= '<li>' . t('Team-based access control (optional, via field_team on users)') . '</li>';
      $output .= '<li>' . t('Role-based permissions (Administrator, Sales Manager, Sales Rep)') . '</li>';
      $output .= '<li>' . t('Automatic default owner assignment on content creation') . '</li>';
      $output .= '</ul>';
      $output .= '<h3>' . t('Permission Levels') . '</h3>';
      $output .= '<dl>';
      $output .= '<dt>' . t('Administrator') . '</dt>';
      $output .= '<dd>' . t('Full access to all content.') . '</dd>';
      $output .= '<dt>' . t('Sales Manager (or bypass crm team access permission)') . '</dt>';
      $output .= '<dd>' . t('Can view and edit all team content.') . '</dd>';
      $output .= '<dt>' . t('Sales Representative') . '</dt>';
      $output .= '<dd>' . t('Can only view and edit their own content, or content from team members (if teams are configured).') . '</dd>';
      $output .= '</dl>';
      return $output;
  }
}

/**
 * Implements hook_page_attachments().
 * 
 * Attaches full-width layout CSS to all CRM pages.
 */
function crm_page_attachments(array &$attachments) {
  // Get the current route.
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();
  
  // List of CRM route prefixes that should have full-width layout.
  $crm_routes = [
    'crm.',
    'entity.user.',
    'user.',
  ];
  
  // Check if current route matches any CRM routes.
  foreach ($crm_routes as $prefix) {
    if (strpos($route_name, $prefix) === 0) {
      $attachments['#attached']['library'][] = 'crm/crm_layout';
      break;
    }
  }
  
  // Also attach to specific view pages.
  if (strpos($route_name, 'view.') === 0) {
    $view_id = $route_match->getParameter('view_id');
    $crm_views = ['my_contacts', 'my_deals', 'my_organizations', 'my_activities', 'my_projects', 'all_contacts'];
    
    if (in_array($view_id, $crm_views)) {
      $attachments['#attached']['library'][] = 'crm/crm_layout';
    }
    
    // Attach contacts_list library specifically for all_contacts view
    if ($view_id === 'all_contacts') {
      $attachments['#attached']['library'][] = 'crm/contacts_list';
    }
  }
}

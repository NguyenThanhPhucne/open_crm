<?php

/**
 * @file
 * CRM Core module - Access control and data privacy.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_node_access().
 *
 * UNIFIED ACCESS CONTROL using centralized CRMAccessService.
 * 
 * Access Model:
 * - Administrators: Full access
 * - Sales Managers: Access to all team content
 * - Sales Representatives: Access to own content + same team content
 * - Anonymous: No access to CRM data
 */
function crm_node_access(NodeInterface $node, $op, AccountInterface $account) {
  $crm_types = ['contact', 'deal', 'activity', 'organization'];

  // Only apply to CRM content types.
  if (!in_array($node->bundle(), $crm_types)) {
    return AccessResult::neutral();
  }

  // Use the centralized access service.
  $access_service = \Drupal::service('crm.access_service');

  // Delegate to service based on operation.
  $allowed = match ($op) {
    'view' => $access_service->canUserViewEntity($node, $account),
    'update' => $access_service->canUserEditEntity($node, $account),
    'delete' => $access_service->canUserDeleteEntity($node, $account),
    default => TRUE, // Unknown operation, return neutral.
  };

  if ($allowed) {
    return AccessResult::allowed()
      ->cachePerUser()
      ->addCacheableDependency($node);
  } else {
    return AccessResult::forbidden('You do not have permission to access this record')
      ->cachePerUser()
      ->addCacheableDependency($node);
  }
}

/**
 * Implements hook_query_TAG_alter() for 'node_access'.
 *
 * Automatically filters node queries to respect role-based access control.
 * This applies to Views, entity queries, and other database queries tagged with 'node_access'.
 *
 * Filtering strategy:
 * - Admins: No filtering (see all records)
 * - Sales Managers: No filtering (see all records)
 * - Sales Reps: Filter by ownership and team
 * - Anonymous: Deny all CRM data
 */
function crm_query_node_access_alter(\Drupal\Core\Database\Query\AlterableInterface $query) {
  $account = \Drupal::currentUser();
  $access_service = \Drupal::service('crm.access_service');

  // Find the node_field_data table in the query.
  $tables = $query->getTables();
  $node_table_alias = NULL;

  foreach ($tables as $table) {
    if (isset($table['table']) && $table['table'] === 'node_field_data') {
      $node_table_alias = $table['alias'];
      break;
    }
  }

  // If no node table found, skip filtering.
  if (!$node_table_alias) {
    return;
  }

  // Apply access filtering using the centralized service.
  $access_service->applyAccessFiltering($query, $account, $node_table_alias);
}

/**
 * Implements hook_form_alter().
 *
 * Sets default owner = current user when creating new CRM content.
 */
function crm_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Only apply to node forms.
  if (strpos($form_id, 'node_') !== 0) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  $node = $form_object->getEntity();

  // Only for new nodes.
  if (!$node->isNew()) {
    return;
  }

  $crm_types = ['contact', 'deal'];
  $current_user = \Drupal::currentUser();

  // Set field_owner for Contact and Deal.
  if (in_array($node->bundle(), $crm_types)) {
    if (isset($form['field_owner'])) {
      $form['field_owner']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }

  // Set field_assigned_staff for Organization.
  if ($node->bundle() === 'organization') {
    if (isset($form['field_assigned_staff'])) {
      $form['field_assigned_staff']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }

  // Set field_assigned_to for Activity.
  if ($node->bundle() === 'activity') {
    if (isset($form['field_assigned_to'])) {
      $form['field_assigned_to']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }
}

/**
 * Implements hook_node_presave().
 *
 * Comprehensive validation for CRM entities:
 * - Ensures owner/assignment fields are set
 * - Validates stage format and values
 * - Validates deal amounts are non-negative
 * - Ensures entity relationships are valid
 * - Prevents orphaned entities
 */
function crm_node_presave(NodeInterface $node) {
  $bundle = $node->bundle();
  $current_user = \Drupal::currentUser();
  $valid_stages = ['qualified', 'proposal', 'negotiation', 'closed_won', 'closed_lost'];

  // DEALS - Comprehensive validation
  if ($bundle === 'deal') {
    // Requirement 1: Deal must have owner
    if ($node->get('field_owner')->isEmpty()) {
      if ($current_user->id() > 0) {
        $node->set('field_owner', $current_user->id());
        \Drupal::logger('crm')->info('Auto-assigned deal #@id to user @user', 
          ['@id' => $node->id() ?: 'new', '@user' => $current_user->getDisplayName()]);
      }
    }

    // Requirement 2: Stage must be valid string format
    if (!$node->get('field_stage')->isEmpty()) {
      $stage = $node->get('field_stage')->value;
      
      // Handle legacy numeric stage IDs and convert to string
      if (is_numeric($stage)) {
        $stage_map = [1 => 'qualified', 2 => 'proposal', 3 => 'negotiation', 5 => 'closed_won', 6 => 'closed_lost'];
        if (isset($stage_map[$stage])) {
          $stage = $stage_map[$stage];
          $node->set('field_stage', $stage);
        }
      }
      
      // Validate stage value
      if (!in_array($stage, $valid_stages)) {
        throw new \InvalidArgumentException(
          sprintf('Invalid stage: %s. Must be one of: %s', $stage, implode(', ', $valid_stages))
        );
      }
    }

    // Requirement 3: Amount must be non-negative
    if (!$node->get('field_amount')->isEmpty()) {
      $amount = floatval($node->get('field_amount')->value);
      if ($amount < 0) {
        throw new \InvalidArgumentException('Deal amount cannot be negative. Amount: ' . $amount);
      }
    }

    // Requirement 4: Deal must reference Contact OR Organization (at least one)
    $has_contact = !$node->get('field_contact')->isEmpty();
    $has_org = !$node->get('field_organization')->isEmpty();
    
    if (!$has_contact && !$has_org) {
      throw new \InvalidArgumentException(
        'Deal must reference at least one: Contact or Organization'
      );
    }
  }

  // ACTIVITIES - Comprehensive validation
  if ($bundle === 'activity') {
    // Requirement 1: Activity must be assigned to user
    if ($node->get('field_assigned_to')->isEmpty()) {
      if ($current_user->id() > 0) {
        $node->set('field_assigned_to', $current_user->id());
        \Drupal::logger('crm')->info('Auto-assigned activity #@id to user @user',
          ['@id' => $node->id() ?: 'new', '@user' => $current_user->getDisplayName()]);
      }
    }

    // Requirement 2: Activity must reference Contact OR Deal (at least one)
    $has_contact = !$node->get('field_contact')->isEmpty();
    $has_deal = !$node->get('field_deal')->isEmpty();
    
    if (!$has_contact && !$has_deal) {
      throw new \InvalidArgumentException(
        'Activity must reference at least one: Contact or Deal'
      );
    }
  }

  // CONTACTS - Validation
  if ($bundle === 'contact') {
    if ($node->get('field_phone')->isEmpty()) {
      throw new \InvalidArgumentException('Phone number is required for contacts');
    }
    
    // Set owner if empty
    if ($node->get('field_owner')->isEmpty() && $current_user->id() > 0) {
      $node->set('field_owner', $current_user->id());
    }
  }

  // ORGANIZATIONS - Validation
  if ($bundle === 'organization') {
    // Set assigned_staff if empty
    if ($node->get('field_assigned_staff')->isEmpty() && $current_user->id() > 0) {
      $node->set('field_assigned_staff', $current_user->id());
    }
  }
}


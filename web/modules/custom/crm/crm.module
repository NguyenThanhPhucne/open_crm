<?php

/**
 * @file
 * CRM Core module - Access control and data privacy.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Session\AccountInterface;
use Drupal\node\NodeInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_node_access().
 *
 * UNIFIED ACCESS CONTROL using centralized CRMAccessService.
 * 
 * Access Model:
 * - Administrators: Full access
 * - Sales Managers: Access to all team content
 * - Sales Representatives: Access to own content + same team content
 * - Anonymous: No access to CRM data
 */
function crm_node_access(NodeInterface $node, $op, AccountInterface $account) {
  $crm_types = ['contact', 'deal', 'activity', 'organization'];

  // Only apply to CRM content types.
  if (!in_array($node->bundle(), $crm_types)) {
    return AccessResult::neutral();
  }

  // Use the centralized access service.
  $access_service = \Drupal::service('crm.access_service');

  // Delegate to service based on operation.
  $allowed = match ($op) {
    'view' => $access_service->canUserViewEntity($node, $account),
    'update' => $access_service->canUserEditEntity($node, $account),
    'delete' => $access_service->canUserDeleteEntity($node, $account),
    default => TRUE, // Unknown operation, return neutral.
  };

  if ($allowed) {
    return AccessResult::allowed()
      ->cachePerUser()
      ->addCacheableDependency($node);
  } else {
    return AccessResult::forbidden('You do not have permission to access this record')
      ->cachePerUser()
      ->addCacheableDependency($node);
  }
}

/**
 * Implements hook_query_TAG_alter() for 'node_access'.
 *
 * Automatically filters node queries to respect role-based access control.
 * This applies to Views, entity queries, and other database queries tagged with 'node_access'.
 *
 * Filtering strategy:
 * - Admins: No filtering (see all records)
 * - Sales Managers: No filtering (see all records)
 * - Sales Reps: Filter by ownership and team
 * - Anonymous: Deny all CRM data
 */
function crm_query_node_access_alter(\Drupal\Core\Database\Query\AlterableInterface $query) {
  $account = \Drupal::currentUser();
  $access_service = \Drupal::service('crm.access_service');

  // Find the node_field_data table in the query.
  $tables = $query->getTables();
  $node_table_alias = NULL;

  foreach ($tables as $table) {
    if (isset($table['table']) && $table['table'] === 'node_field_data') {
      $node_table_alias = $table['alias'];
      break;
    }
  }

  // If no node table found, skip filtering.
  if (!$node_table_alias) {
    return;
  }

  // Apply access filtering using the centralized service.
  $access_service->applyAccessFiltering($query, $account, $node_table_alias);
}

/**
 * Implements hook_form_alter().
 *
 * Sets default owner = current user when creating new CRM content.
 */
function crm_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Only apply to node forms.
  if (strpos($form_id, 'node_') !== 0) {
    return;
  }

  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  $node = $form_object->getEntity();

  // ── ClickUp-style UI for CRM content type forms (add & edit) ───────
  $crm_types_ui = ['contact', 'organization', 'deal', 'activity'];
  if (in_array($node->bundle(), $crm_types_ui)) {
    $type = $node->bundle();
    $is_new = $node->isNew();

    // Add CSS classes to the form element.
    $form['#attributes']['class'][] = 'crm-node-form';
    $form['#attributes']['class'][] = 'crm-form--' . $type;

    // Attach the form style library.
    $form['#attached']['library'][] = 'crm/node_form_styles';

    // Per-type configuration for the header banner.
    $header_config = [
      'contact' => [
        'new_label'  => 'New Contact',
        'edit_label' => 'Edit Contact',
        'new_desc'   => 'Add a person to your CRM network',
        'edit_desc'  => 'Update contact information',
        'icon_path'  => 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
      ],
      'organization' => [
        'new_label'  => 'New Organization',
        'edit_label' => 'Edit Organization',
        'new_desc'   => 'Create a new company or account record',
        'edit_desc'  => 'Update organization information',
        'icon_path'  => 'M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2zM9 22V12h6v10',
      ],
      'deal' => [
        'new_label'  => 'New Deal',
        'edit_label' => 'Edit Deal',
        'new_desc'   => 'Track a new sales opportunity in your pipeline',
        'edit_desc'  => 'Update deal details',
        'icon_path'  => 'M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6',
      ],
      'activity' => [
        'new_label'  => 'Log Activity',
        'edit_label' => 'Edit Activity',
        'new_desc'   => 'Record a call, meeting, email or task',
        'edit_desc'  => 'Update activity details',
        'icon_path'  => 'M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01',
      ],
    ];

    $cfg   = $header_config[$type];
    $label = $is_new ? $cfg['new_label']  : $cfg['edit_label'];
    $desc  = $is_new ? $cfg['new_desc']   : $cfg['edit_desc'];
    if (!$is_new && $node->id() && $node->getTitle()) {
      $desc = $node->getTitle();
    }

    $icon_svg = '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" '
      . 'viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" '
      . 'stroke-linecap="round" stroke-linejoin="round">'
      . '<path d="' . $cfg['icon_path'] . '"/>'
      . '</svg>';

    $header_html = '<div class="crm-form-header">'
      . '<div class="crm-form-header-icon">' . $icon_svg . '</div>'
      . '<div class="crm-form-header-text">'
      . '<h2>' . htmlspecialchars($label, ENT_QUOTES, 'UTF-8') . '</h2>'
      . '<p>' . htmlspecialchars($desc, ENT_QUOTES, 'UTF-8') . '</p>'
      . '</div></div>';

    $form['crm_form_header'] = [
      '#markup' => Markup::create($header_html),
      '#weight' => -200,
    ];

    // Add a "Use CRM Editor" notice for existing records (edit forms).
    if (!$is_new && $node->id()) {
      $type_urls = [
        'contact'      => '/crm/all-contacts',
        'organization' => '/crm/all-organizations',
        'deal'         => '/crm/all-deals',
        'activity'     => '/crm/all-activities',
      ];
      $list_url = $type_urls[$type] ?? '/crm/dashboard';
      $nid = $node->id();
      $notice_html = '<div class="crm-edit-notice">'
        . '<div class="crm-edit-notice-icon"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg></div>'
        . '<div class="crm-edit-notice-text">'
        . '<strong>Prefer the CRM Editor?</strong> '
        . 'For a faster editing experience, use the inline edit panel in the CRM view.</div>'
        . '<a href="' . htmlspecialchars($list_url, ENT_QUOTES, 'UTF-8') . '" class="crm-edit-notice-btn">Go to CRM view</a>'
        . '</div>';
      $form['crm_edit_notice'] = [
        '#markup' => Markup::create($notice_html),
        '#weight' => -199,
      ];
    }
  }

  // Only for new nodes (auto-fill owner defaults).
  if (!$node->isNew()) {
    return;
  }

  $crm_types = ['contact', 'deal'];
  $current_user = \Drupal::currentUser();

  // Set field_owner for Contact and Deal.
  if (in_array($node->bundle(), $crm_types)) {
    if (isset($form['field_owner'])) {
      $form['field_owner']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }

  // Set field_assigned_staff for Organization.
  if ($node->bundle() === 'organization') {
    if (isset($form['field_assigned_staff'])) {
      $form['field_assigned_staff']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }

  // Set field_assigned_to for Activity.
  if ($node->bundle() === 'activity') {
    if (isset($form['field_assigned_to'])) {
      $form['field_assigned_to']['widget'][0]['target_id']['#default_value'] =
        \Drupal\user\Entity\User::load($current_user->id());
    }
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for user_form.
 */
function crm_form_user_form_alter(&$form, FormStateInterface $form_state) {
  $form_object = $form_state->getFormObject();
  if (!method_exists($form_object, 'getEntity')) {
    return;
  }

  /** @var \Drupal\user\UserInterface|null $account */
  $account = $form_object->getEntity();
  if (!$account) {
    return;
  }

  $display_name = trim((string) $account->getDisplayName()) ?: 'User';
  $display_name = ucfirst($display_name);
  $email = (string) $account->getEmail();
  $initial = strtoupper(mb_substr($display_name, 0, 1));
  $is_own_profile = ((int) \Drupal::currentUser()->id() === (int) $account->id());
  $subtitle = $is_own_profile
    ? 'Keep your profile, credentials, language, and team settings aligned with the CRM workspace.'
    : 'Update this team member\'s account details, preferences, and access settings.';

  $team_name = 'No team assigned';
  if ($account->hasField('field_team') && !$account->get('field_team')->isEmpty() && $account->get('field_team')->entity) {
    $team_name = $account->get('field_team')->entity->label();
  }

  $member_since = \Drupal::service('date.formatter')->format($account->getCreatedTime(), 'custom', 'M Y');
  $profile_url = \Drupal\Core\Url::fromRoute('crm.user_profile', ['user' => $account->id()])->toString();
  $dashboard_url = '/crm/dashboard';

  $has_picture = FALSE;
  $user_picture_markup = '<div class="crm-user-edit-avatar crm-user-edit-avatar--placeholder"><span class="avatar-initial">'
    . htmlspecialchars($initial, ENT_QUOTES, 'UTF-8')
    . '</span></div>';
  if ($account->hasField('user_picture') && !$account->get('user_picture')->isEmpty() && $account->get('user_picture')->entity) {
    $picture = $account->get('user_picture')->entity;
    $file_uri = $picture->getFileUri();
    $image_style = \Drupal::entityTypeManager()->getStorage('image_style')->load('thumbnail');
    $picture_url = $image_style
      ? $image_style->buildUrl($file_uri)
      : \Drupal::service('file_url_generator')->generateAbsoluteString($file_uri);
    $user_picture_markup = '<img src="' . htmlspecialchars($picture_url, ENT_QUOTES, 'UTF-8') . '" alt="' . htmlspecialchars($display_name, ENT_QUOTES, 'UTF-8') . '" class="crm-user-edit-avatar" />';
    $has_picture = TRUE;
  }

  $hero_html = '<div class="crm-user-edit-hero">'
    . '<div class="crm-user-edit-cover"></div>'
    . '<div class="crm-user-edit-hero__body">'
    . '<div class="crm-user-edit-avatar-section">'
    . $user_picture_markup
    . '<span class="crm-user-edit-avatar-status' . ($has_picture ? ' is-custom' : '') . '"></span>'
    . '</div>'
    . '<div class="crm-user-edit-identity">'
    . '<div class="crm-user-edit-hero__eyebrow">Account settings</div>'
    . '<div class="crm-user-edit-name-row">'
    . '<h1 class="crm-user-edit-hero__title">' . htmlspecialchars($display_name, ENT_QUOTES, 'UTF-8') . '</h1>'
    . '<a href="' . htmlspecialchars($profile_url, ENT_QUOTES, 'UTF-8') . '" class="crm-user-edit-inline-link">View profile</a>'
    . '</div>'
    . '<p class="crm-user-edit-hero__subtitle">' . htmlspecialchars($subtitle, ENT_QUOTES, 'UTF-8') . '</p>'
    . '<div class="crm-user-edit-hero__meta">'
    . '<span class="crm-user-edit-meta-chip">' . htmlspecialchars($email ?: 'No email address', ENT_QUOTES, 'UTF-8') . '</span>'
    . '<span class="crm-user-edit-meta-chip">' . htmlspecialchars($team_name, ENT_QUOTES, 'UTF-8') . '</span>'
    . '<span class="crm-user-edit-meta-chip">Joined ' . htmlspecialchars($member_since, ENT_QUOTES, 'UTF-8') . '</span>'
    . '</div></div>'
    . '<div class="crm-user-edit-quick-actions">'
    . '<a href="' . htmlspecialchars($profile_url, ENT_QUOTES, 'UTF-8') . '" class="crm-user-edit-btn crm-user-edit-btn--primary">Open Profile</a>'
    . '<a href="' . htmlspecialchars($dashboard_url, ENT_QUOTES, 'UTF-8') . '" class="crm-user-edit-btn crm-user-edit-btn--secondary">CRM Dashboard</a>'
    . '</div></div></div>';

  $form['#attributes']['class'][] = 'crm-user-edit-form';
  $form['#attached']['library'][] = 'crm/user_edit_styles';

  if (isset($form['actions']['submit']['#attributes']['class'])) {
    $form['actions']['submit']['#attributes']['class'][] = 'crm-user-edit-submit';
  }
  else {
    $form['actions']['submit']['#attributes']['class'] = ['crm-user-edit-submit'];
  }

  if (isset($form['actions']['#attributes']['class'])) {
    $form['actions']['#attributes']['class'][] = 'crm-user-edit-actions';
  }
  else {
    $form['actions']['#attributes']['class'] = ['crm-user-edit-actions'];
  }

  foreach (['account', 'user_picture', 'user_picture_wrapper', 'timezone', 'roles', 'status', 'field_team', 'gin_theme_settings'] as $key) {
    if (isset($form[$key]['#attributes']['class'])) {
      $form[$key]['#attributes']['class'][] = 'crm-user-edit-section-target';
    }
    elseif (isset($form[$key])) {
      $form[$key]['#attributes']['class'] = ['crm-user-edit-section-target'];
    }
  }

  $form['crm_user_edit_header'] = [
    '#markup' => Markup::create($hero_html),
    '#weight' => -200,
  ];
}

/**
 * Implements hook_node_presave().
 *
 * Comprehensive validation for CRM entities:
 * - Ensures owner/assignment fields are set
 * - Validates stage format and values
 * - Validates deal amounts are non-negative
 * - Ensures entity relationships are valid
 * - Prevents orphaned entities
 */
function crm_node_presave(NodeInterface $node) {
  $bundle = $node->bundle();
  $current_user = \Drupal::currentUser();

  // DEALS - Comprehensive validation
  if ($bundle === 'deal') {
    // Requirement 1: Deal must have owner
    if ($node->get('field_owner')->isEmpty()) {
      if ($current_user->id() > 0) {
        $node->set('field_owner', $current_user->id());
        \Drupal::logger('crm')->info('Auto-assigned deal #@id to user @user', 
          ['@id' => $node->id() ?: 'new', '@user' => $current_user->getDisplayName()]);
      }
    }

    // Requirement 2: Stage must be a valid pipeline_stage taxonomy term.
    if (!$node->get('field_stage')->isEmpty()) {
      // field_stage is an entity_reference to pipeline_stage; read target_id.
      $stage_tid = (int) $node->get('field_stage')->target_id;

      // Validate directly against the taxonomy vocabulary instead of a stale
      // hard-coded stage map so custom terms remain valid.
      $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($stage_tid);
      if (!$term || $term->bundle() !== 'pipeline_stage') {
        throw new \InvalidArgumentException(
          sprintf('Invalid stage term ID: %d. Must reference a valid pipeline_stage term.', $stage_tid)
        );
      }
    }

    // Requirement 3: Amount must be non-negative
    if (!$node->get('field_amount')->isEmpty()) {
      $amount = floatval($node->get('field_amount')->value);
      if ($amount < 0) {
        throw new \InvalidArgumentException('Deal amount cannot be negative. Amount: ' . $amount);
      }
    }

    // Requirement 4: Deal must reference Contact OR Organization (at least one)
    $has_contact = !$node->get('field_contact')->isEmpty();
    $has_org = !$node->get('field_organization')->isEmpty();
    
    if (!$has_contact && !$has_org) {
      throw new \InvalidArgumentException(
        'Deal must reference at least one: Contact or Organization'
      );
    }
  }

  // ACTIVITIES - Comprehensive validation
  if ($bundle === 'activity') {
    // Requirement 1: Activity must be assigned to user
    if ($node->get('field_assigned_to')->isEmpty()) {
      if ($current_user->id() > 0) {
        $node->set('field_assigned_to', $current_user->id());
        \Drupal::logger('crm')->info('Auto-assigned activity #@id to user @user',
          ['@id' => $node->id() ?: 'new', '@user' => $current_user->getDisplayName()]);
      }
    }

    // Requirement 2: Activity must reference Contact OR Deal (at least one)
    $has_contact = !$node->get('field_contact')->isEmpty();
    $has_deal = !$node->get('field_deal')->isEmpty();
    
    if (!$has_contact && !$has_deal) {
      throw new \InvalidArgumentException(
        'Activity must reference at least one: Contact or Deal'
      );
    }
  }

  // CONTACTS - Validation
  if ($bundle === 'contact') {
    if ($node->get('field_phone')->isEmpty()) {
      throw new \InvalidArgumentException('Phone number is required for contacts');
    }
    
    // Set owner if empty
    if ($node->get('field_owner')->isEmpty() && $current_user->id() > 0) {
      $node->set('field_owner', $current_user->id());
    }
  }

  // ORGANIZATIONS - Validation
  if ($bundle === 'organization') {
    // Set assigned_staff if empty
    if ($node->get('field_assigned_staff')->isEmpty() && $current_user->id() > 0) {
      $node->set('field_assigned_staff', $current_user->id());
    }
  }
}


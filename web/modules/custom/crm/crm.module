/**
 * Helper function: Check if two users are in the same team.
 * 
 * @param int $uid1
 *   First user ID.
 * @param int $uid2
 *   Second user ID.
 * 
 * @return bool
 *   TRUE if same team, FALSE otherwise.
 */
function _crm_check_same_team($uid1, $uid2) {
  $team1 = _crm_get_user_team($uid1);
  $team2 = _crm_get_user_team($uid2);
  
  // If either user has no team, return FALSE (no team-based access).
  if (empty($team1) || empty($team2)) {
    return FALSE;
  }
  
  return ($team1 === $team2);
}

/**
 * Helper function: Get user's team ID.
 * 
 * @param int $uid
 *   User ID.
 * 
 * @return int|null
 *   Team taxonomy term ID or NULL.
 */
function _crm_get_user_team($uid) {
  $user = \Drupal::entityTypeManager()->getStorage('user')->load($uid);
  
  if ($user && $user->hasField('field_team') && !$user->get('field_team')->isEmpty()) {
    return $user->get('field_team')->target_id;
  }
  
  return NULL;
}

/**
 * Helper function: Get entity owner's team ID.
 * 
 * @param \Drupal\Core\Entity\EntityInterface $entity
 *   The entity (node).
 * 
 * @return int|null
 *   Team taxonomy term ID or NULL.
 */
function _crm_get_entity_owner_team(\Drupal\Core\Entity\EntityInterface $entity) {
  if ($entity->hasField('uid')) {
    $owner = $entity->get('uid')->entity;
    
    if ($owner) {
      return _crm_get_user_team($owner->id());
    }
  }
  
  return NULL;
}

/**
 * Implements hook_help().
 */
function crm_help($route_name, \Drupal\Core\Routing\RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.crm':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('CRM Core module provides unified access control for Open CRM system.') . '</p>';
      $output .= '<h3>' . t('Access Control Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Owner-based access control (field_owner, field_assigned_to, field_assigned_staff)') . '</li>';
      $output .= '<li>' . t('Team-based access control (optional, via field_team on users)') . '</li>';
      $output .= '<li>' . t('Role-based permissions (Administrator, Sales Manager, Sales Rep)') . '</li>';
      $output .= '<li>' . t('Automatic default owner assignment on content creation') . '</li>';
      $output .= '</ul>';
      $output .= '<h3>' . t('Permission Levels') . '</h3>';
      $output .= '<dl>';
      $output .= '<dt>' . t('Administrator') . '</dt>';
      $output .= '<dd>' . t('Full access to all content.') . '</dd>';
      $output .= '<dt>' . t('Sales Manager (or bypass crm team access permission)') . '</dt>';
      $output .= '<dd>' . t('Can view and edit all team content.') . '</dd>';
      $output .= '<dt>' . t('Sales Representative') . '</dt>';
      $output .= '<dd>' . t('Can only view and edit their own content, or content from team members (if teams are configured).') . '</dd>';
      $output .= '</dl>';
      return $output;
  }
}

/**
 * Implements hook_page_attachments().
 * 
 * Attaches full-width layout CSS to all CRM pages.
 */
function crm_page_attachments(array &$attachments) {
  // Get the current route.
  $route_match = \Drupal::routeMatch();
  $route_name = $route_match->getRouteName();
  
  // List of CRM route prefixes that should have full-width layout.
  $crm_routes = [
    'crm.',
    'entity.user.',
    'user.',
  ];
  
  // Check if current route matches any CRM routes.
  foreach ($crm_routes as $prefix) {
    if (strpos($route_name, $prefix) === 0) {
      $attachments['#attached']['library'][] = 'crm/crm_layout';
      break;
    }
  }
  
  // Also attach to specific view pages.
  if (strpos($route_name, 'view.') === 0) {
    $view_id = $route_match->getParameter('view_id');
    $crm_views = ['my_contacts', 'my_deals', 'my_organizations', 'my_activities', 'my_projects', 'all_contacts'];
    
    if (in_array($view_id, $crm_views)) {
      $attachments['#attached']['library'][] = 'crm/crm_layout';
    }
    
    // Attach contacts_list library specifically for all_contacts view
    if ($view_id === 'all_contacts') {
      $attachments['#attached']['library'][] = 'crm/contacts_list';
    }
  }
}

/**
 * Implements hook_views_pre_view().
 *
 * For anonymous users: bypass the 'current_user' contextual argument on
 * personal views (my_contacts, my_deals, etc.) so all published CRM records
 * are visible in read-only demo mode.
 */
function crm_views_pre_view(\Drupal\views\ViewExecutable $view, $display_id, array &$args) {
  $personal_views = ['my_contacts', 'my_deals', 'my_activities', 'my_organizations'];
  if (!in_array($view->id(), $personal_views)) {
    return;
  }

  $account = \Drupal::currentUser();
  if (!$account->isAnonymous()) {
    return;
  }

  // Change default_action from 'default' (inject uid=0) to 'ignore' (show all).
  // Guard: display_handler may not be initialized in all call contexts.
  $display_handler = $view->display_handler ?? ($view->displayHandlers ? $view->displayHandlers->get($display_id) : NULL);
  if (!$display_handler) {
    return;
  }

  $argument_options = $display_handler->getOption('arguments');
  if (!empty($argument_options)) {
    foreach ($argument_options as &$opt) {
      $opt['default_action'] = 'ignore';
    }
    $display_handler->setOption('arguments', $argument_options);
  }
}

/**
 * Implements hook_preprocess_views_view().
 *
 * Injects a rich empty-state UI when a CRM list view returns no rows,
 * replacing the blank page with a clear "no data" message.
 */
function crm_preprocess_views_view(array &$variables) {
  $view = $variables['view'];

  $crm_list_views = [
    'my_contacts'      => ['icon' => 'users',      'label' => 'contacts',      'type' => 'contacts'],
    'my_deals'         => ['icon' => 'briefcase',  'label' => 'deals',         'type' => 'deals'],
    'my_activities'    => ['icon' => 'calendar',   'label' => 'activities',    'type' => 'activities'],
    'my_organizations' => ['icon' => 'building-2', 'label' => 'organizations', 'type' => 'organizations'],
    'all_contacts'     => ['icon' => 'users',      'label' => 'contacts',      'type' => 'contacts'],
    'all_organizations'=> ['icon' => 'building-2', 'label' => 'organizations', 'type' => 'organizations'],
    'all_activities'   => ['icon' => 'calendar',   'label' => 'activities',    'type' => 'activities'],
    'all_deals'        => ['icon' => 'briefcase',  'label' => 'deals',         'type' => 'deals'],
  ];

  if (!isset($crm_list_views[$view->id()])) {
    return;
  }

  // Only inject if there are truly no rows AND no empty text already configured.
  $has_rows = !empty($variables['rows']);
  $has_empty = !empty($variables['empty']);
  if ($has_rows || $has_empty) {
    return;
  }

  $info    = $crm_list_views[$view->id()];
  $account = \Drupal::currentUser();

  // Per-type descriptions and add-record links (used for logged-in users).
  $descriptions = [
    'contacts'      => 'Keep all your client details organized and easy to find.',
    'deals'         => 'Track your pipeline stages and close more revenue.',
    'activities'    => 'Log calls, emails, and meetings to stay on top of every interaction.',
    'organizations' => 'Manage all the companies and accounts you work with.',
  ];
  $add_map = [
    'contacts'      => ['url' => '/crm/add/contact',      'icon' => 'user-plus',    'label' => 'Add Contact'],
    'deals'         => ['url' => '/crm/add/deal',         'icon' => 'trending-up',  'label' => 'Add Deal'],
    'activities'    => ['url' => '/crm/add/activity',     'icon' => 'calendar-plus','label' => 'Log Activity'],
    'organizations' => ['url' => '/crm/add/organization', 'icon' => 'building-2',   'label' => 'Add Organization'],
  ];

  $type = $info['type'];

  if ($account->isAnonymous()) {
    $title   = 'No ' . $info['label'] . ' yet';
    $sub     = 'Sign in to your CRM account to view and manage ' . $info['label'] . '.';
    $actions =
      '<a href="/login" class="crm-empty-cta">' .
        '<i data-lucide="log-in"></i> Sign In to Continue' .
      '</a>';
  }
  else {
    $add     = $add_map[$type];
    $title   = 'No ' . $info['label'] . ' found';
    $sub     = $descriptions[$type];
    $actions =
      '<a href="' . $add['url'] . '" class="crm-empty-cta">' .
        '<i data-lucide="' . $add['icon'] . '"></i> ' . $add['label'] .
      '</a>';
  }

  $variables['empty'] = [
    '#markup' => \Drupal\Core\Render\Markup::create(
      '<div class="crm-empty-state" style="text-align:center;">' .
        '<div class="crm-empty-icon"><i data-lucide="' . $info['icon'] . '"></i></div>' .
        '<h3 class="crm-empty-title">' . $title . '</h3>' .
        '<p class="crm-empty-sub" style="text-align:center;">' . $sub . '</p>' .
        '<div class="crm-empty-actions">' . $actions . '</div>' .
      '</div>'
    ),
    '#attached' => ['library' => ['crm_actions/global_nav']],
  ];
}

{#
/**
 * @file
 * Enhanced Contacts List Template
 *
 * Features:
 * - Responsive tables (mobile-friendly)
 * - Real-time inline editing with data sync
 * - Instant field updates (no page reload)
 * - Conflict detection for concurrent edits
 * - Loading states and validation feedback
 * - Professional ClickUp-style design
 */
#}

<div class="contacts-wrapper">
  {# Header #}
  <div class="contacts-header">
    <div class="header-left">
      <h1>Contacts</h1>
      <span class="filter-count">{{ contacts|length }} contacts</span>
    </div>
    
    <div class="header-actions">
      <a href="/crm/add/contact" class="btn btn-primary">
        <i data-lucide="plus" width="16" height="16"></i>Add Contact
      </a>
      {% if ai_autocomplete_enabled %}
        <a href="{{ path('crm_ai_autocomplete.generate_contact') }}" class="btn btn-secondary">
          <i data-lucide="sparkles" width="16" height="16"></i>AI Generate
        </a>
      {% endif %}
    </div>
  </div>

  {# Contacts Table #}
  {% if contacts|length > 0 %}
    <div class="table-wrapper">
      <table class="crm-entities-list" id="crm-contacts-table">
        <thead>
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Company</th>
            <th scope="col">Email</th>
            <th scope="col">Phone</th>
            <th scope="col">Owner</th>
            <th scope="col">Updated</th>
            <th scope="col" style="text-align: right;">Actions</th>
          </tr>
        </thead>
        <tbody>
          {% for contact in contacts %}
            <tr class="contact-row" id="contact-row-{{ contact.nid }}" data-entity-id="{{ contact.nid }}" data-entity-type="contact">
              
              {# Name (Link) #}
              <td data-label="Name">
                <a href="/node/{{ contact.nid }}" class="contact-name-link">
                  {{ contact.name }}
                </a>
              </td>

              {# Company #}
              <td data-label="Company" data-field-name="field_organization" data-editable="true" data-entity-id="{{ contact.nid }}">
                <span class="field-display-value">{{ contact.organization ?? '—' }}</span>
              </td>

              {# Email (Editable) #}
              <td data-label="Email" data-field-name="field_email" data-editable="true" data-entity-id="{{ contact.nid }}">
                <span class="field-display-value">{{ contact.email ?? '—' }}</span>
              </td>

              {# Phone (Editable) #}
              <td data-label="Phone" data-field-name="field_phone" data-editable="true" data-entity-id="{{ contact.nid }}">
                <span class="field-display-value">{{ contact.phone ?? '—' }}</span>
              </td>

              {# Owner #}
              <td data-label="Owner">
                <span class="badge badge-info">{{ contact.owner_name ?? 'Unassigned' }}</span>
              </td>

              {# Last Updated #}
              <td data-label="Updated" class="td-time">
                <span class="text-muted text-small">
                  {{ contact.changed_relative ?? 'just now' }}
                </span>
              </td>

              {# Actions #}
              <td style="text-align: right;">
                <div class="action-buttons">
                  <a href="/crm/edit/contact/{{ contact.nid }}" class="btn btn-sm btn-secondary" title="Edit full form">
                    <i data-lucide="edit-2" width="14" height="14"></i>
                  </a>
                  <button type="button" class="btn btn-sm btn-danger delete-btn" data-nid="{{ contact.nid }}" data-name="{{ contact.name }}" title="Delete contact">
                    <i data-lucide="trash-2" width="14" height="14"></i>
                  </button>
                </div>
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  {% else %}
    <div class="empty-state">
      <div class="empty-state-icon">
        <i data-lucide="users" width="48" height="48"></i>
      </div>
      <h2>No contacts yet</h2>
      <p>Get started by creating your first contact</p>
      <a href="/crm/add/contact" class="btn btn-primary">
        <i data-lucide="plus" width="16" height="16"></i>Create Contact
      </a>
    </div>
  {% endif %}
</div>

{# Delete Confirmation Modal — ClickUp-style #}
<dialog id="delete-modal" class="crm-delete-modal" aria-modal="true" aria-labelledby="delete-modal-title" aria-hidden="true">
  <div class="crm-delete-modal__overlay"></div>
  <div class="crm-delete-modal__card">
    <div class="crm-delete-modal__header">
      <div class="crm-delete-modal__icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
      </div>
      <div>
        <h3 id="delete-modal-title" class="crm-delete-modal__title">Delete Contact?</h3>
        <p class="crm-delete-modal__sub">Type the contact name to confirm permanent deletion.</p>
      </div>
      <button type="button" class="crm-delete-modal__close" aria-label="Close">&times;</button>
    </div>
    <div class="crm-delete-modal__body">
      <p class="crm-delete-modal__prompt">Type <strong id="delete-name-confirm"></strong> to confirm:</p>
      <input type="text" id="delete-confirm-input" class="crm-delete-modal__input" autocomplete="off" spellcheck="false" placeholder="Type name here…"/>
      <p class="crm-delete-modal__warn">⚠ This cannot be undone. All related references will be cleared.</p>
    </div>
    <div class="crm-delete-modal__footer">
      <button type="button" class="crm-delete-modal__btn crm-delete-modal__btn--cancel" id="delete-cancel-btn">Cancel</button>
      <button type="button" class="crm-delete-modal__btn crm-delete-modal__btn--danger" id="delete-confirm-btn" disabled>Delete permanently</button>
    </div>
  </div>
</dialog>

<style>
/* Wrapper */
.contacts-wrapper {
  max-width: 1400px;
  margin: 0 auto;
  padding: 24px;
}

/* Header */
.contacts-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
  gap: 16px;
}

.contacts-header h1 {
  margin: 0;
  font-size: 28px;
  color: #1f2937;
  font-weight: 700;
}

.filter-count {
  display: inline-block;
  margin-left: 12px;
  font-size: 14px;
  color: #6b7280;
  background: #f3f4f6;
  padding: 4px 8px;
  border-radius: 16px;
}

.header-actions {
  display: flex;
  gap: 8px;
}

/* Table Wrapper */
.table-wrapper {
  overflow-x: auto;
  border-radius: 16px;
  background: white;
  box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.08);
}

/* Table styling */
.crm-entities-list tbody tr:hover td {
  background: #f0f7ff;
}

/* Action buttons */
.action-buttons {
  display: flex;
  gap: 4px;
  justify-content: flex-end;
}

/* Empty state */
.empty-state {
  text-align: center;
  padding: 60px 24px;
  background: white;
  border-radius: 16px;
  color: #6b7280;
}

.empty-state-icon {
  display: flex;
  justify-content: center;
  margin-bottom: 16px;
  opacity: 0.6;
}

.empty-state h2 {
  margin: 12px 0 8px;
  color: #374151;
}

.empty-state p {
  margin: 8px 0 24px;
  color: #6b7280;
}

/* ── ClickUp-style delete modal ─────────────────────── */
.crm-delete-modal {
  position: fixed; inset: 0; z-index: 10000;
  display: none; align-items: center; justify-content: center;
}
.crm-delete-modal.is-open,
.crm-delete-modal[aria-hidden="false"] {
  display: flex;
}
.crm-delete-modal__overlay {
  position: absolute; inset: 0;
  background: rgba(15,23,42,.45);
  backdrop-filter: blur(3px);
  animation: crm-fade-in 180ms ease;
}
@keyframes crm-fade-in { from { opacity:0; } to { opacity:1; } }
.crm-delete-modal__card {
  position: relative; z-index: 1;
  width: min(480px, calc(100vw - 32px));
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
  box-shadow: 0 24px 48px rgba(15,23,42,.22);
  animation: crm-slide-up 200ms cubic-bezier(.34,1.56,.64,1);
}
@keyframes crm-slide-up {
  from { opacity:0; transform: translateY(20px) scale(.97); }
  to   { opacity:1; transform: translateY(0) scale(1); }
}
.crm-delete-modal__header {
  display: flex; align-items: flex-start; gap: 14px;
  padding: 20px 20px 16px;
  border-bottom: 1px solid #f1f5f9;
}
.crm-delete-modal__icon {
  flex-shrink: 0; width: 42px; height: 42px;
  background: #fef2f2; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  color: #ef4444;
}
.crm-delete-modal__title {
  margin: 0 0 3px; font-size: 16px; font-weight: 700; color: #0f172a;
}
.crm-delete-modal__sub {
  margin: 0; font-size: 13px; color: #64748b;
}
.crm-delete-modal__close {
  margin-left: auto; flex-shrink: 0;
  background: none; border: none; cursor: pointer;
  width: 28px; height: 28px; font-size: 20px; line-height: 1;
  color: #94a3b8; border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: background .15s, color .15s;
}
.crm-delete-modal__close:hover { background: #f1f5f9; color: #334155; }
.crm-delete-modal__body { padding: 18px 20px; }
.crm-delete-modal__prompt { margin: 0 0 8px; font-size: 13px; color: #334155; }
.crm-delete-modal__prompt strong { font-weight: 700; color: #0f172a; }
.crm-delete-modal__input {
  width: 100%; height: 38px;
  border: 1.5px solid #cbd5e1; border-radius: 16px;
  padding: 0 12px; font-size: 13px; outline: none;
  transition: border-color .15s, box-shadow .15s;
}
.crm-delete-modal__input:focus {
  border-color: #ef4444;
  box-shadow: 0 0 0 3px rgba(239,68,68,.15);
}
.crm-delete-modal__warn {
  margin: 10px 0 0; font-size: 12px;
  color: #b45309; background: #fffbeb;
  border: 1px solid #fde68a; border-radius: 16px;
  padding: 6px 10px;
}
.crm-delete-modal__footer {
  display: flex; justify-content: flex-end; gap: 8px;
  padding: 14px 20px; border-top: 1px solid #f1f5f9;
}
.crm-delete-modal__btn {
  height: 36px; padding: 0 16px; border-radius: 16px;
  border: 1.5px solid #d1d9e6; background: #fff;
  color: #334155; font-size: 13px; font-weight: 600;
  cursor: pointer; transition: background .15s, border-color .15s;
}
.crm-delete-modal__btn:hover { background: #f8fafc; }
.crm-delete-modal__btn--danger {
  background: #ef4444; border-color: #ef4444; color: #fff;
}
.crm-delete-modal__btn--danger:hover {
  background: #dc2626; border-color: #dc2626;
}
.crm-delete-modal__btn--danger.is-loading {
  color: transparent;
  pointer-events: none;
  position: relative;
}
.crm-delete-modal__btn--danger.is-loading::after {
  content: "";
  position: absolute;
  left: 14px;
  right: 14px;
  top: 50%;
  height: 10px;
  border-radius: 999px;
  transform: translateY(-50%);
  background: linear-gradient(90deg, rgba(255,255,255,.28) 25%, rgba(255,255,255,.55) 50%, rgba(255,255,255,.28) 75%);
  background-size: 220% 100%;
  animation: crm-delete-btn-skeleton 1.1s ease-in-out infinite;
}
.crm-delete-modal__card[aria-busy="true"] .crm-delete-modal__input {
  opacity: 0.7;
  pointer-events: none;
}
.crm-delete-modal__btn[disabled] { opacity: .45; cursor: not-allowed; }
@keyframes crm-delete-btn-skeleton {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* Responsive */
@media (max-width: 768px) {
  .contacts-header { flex-direction: column; align-items: flex-start; }
  .header-actions { width: 100%; flex-direction: column; }
  .header-actions .btn { width: 100%; }
  .action-buttons { width: 100%; flex-direction: row; }
  .action-buttons .btn { flex: 1; }
}
</style>

<script>
(function () {
  'use strict';

  var pendingNid = null;
  var pendingName = null;
  var modal = document.getElementById('delete-modal');
  var modalCard = modal ? modal.querySelector('.crm-delete-modal__card') : null;
  var confirmInput = document.getElementById('delete-confirm-input');
  var confirmBtn = document.getElementById('delete-confirm-btn');
  var cancelBtn = document.getElementById('delete-cancel-btn');
  var closeBtn = modal ? modal.querySelector('.crm-delete-modal__close') : null;
  var overlay = modal ? modal.querySelector('.crm-delete-modal__overlay') : null;
  var nameEl = document.getElementById('delete-name-confirm');
  var focusedBeforeOpen = null;
  var triggerButton = null;

  function getFocusableElements() {
    if (!modal) return [];
    var selector = 'a[href], button:not([disabled]), textarea:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.prototype.slice.call(modal.querySelectorAll(selector)).filter(function (el) {
      return el.offsetParent !== null;
    });
  }

  function setModalOpenState(isOpen) {
    if (!modal) return;
    modal.classList.toggle('is-open', isOpen);
    modal.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
    document.body.classList.toggle('crm-modal-open', isOpen);
  }

  function setModalLoadingState(isLoading) {
    if (modalCard) {
      modalCard.setAttribute('aria-busy', isLoading ? 'true' : 'false');
    }
    if (confirmBtn) {
      confirmBtn.classList.toggle('is-loading', isLoading);
    }
  }

  function openModal(nid, name, trigger) {
    pendingNid = nid;
    pendingName = name;
    triggerButton = trigger || null;
    focusedBeforeOpen = document.activeElement;

    if (triggerButton) {
      triggerButton.setAttribute('aria-expanded', 'true');
    }

    if (nameEl) nameEl.textContent = name;
    if (confirmInput) { confirmInput.value = ''; confirmInput.focus(); }
    if (confirmBtn) confirmBtn.disabled = true;
    setModalLoadingState(false);
    setModalOpenState(true);

    var focusables = getFocusableElements();
    if (focusables.length) {
      focusables[0].focus();
    }
  }

  function closeModal() {
    setModalOpenState(false);
    pendingNid = null;
    pendingName = null;
    if (confirmInput) confirmInput.value = '';
    if (confirmBtn) confirmBtn.disabled = true;
    setModalLoadingState(false);

    if (triggerButton) {
      triggerButton.setAttribute('aria-expanded', 'false');
    }

    if (focusedBeforeOpen && typeof focusedBeforeOpen.focus === 'function') {
      focusedBeforeOpen.focus();
    }

    focusedBeforeOpen = null;
    triggerButton = null;
  }

  // Enable confirm button only when name matches exactly
  if (confirmInput && confirmBtn) {
    confirmInput.addEventListener('input', function () {
      confirmBtn.disabled = (confirmInput.value.trim() !== (pendingName || '').trim());
    });
  }

  // Trigger delete
  if (confirmBtn) {
    confirmBtn.addEventListener('click', async function () {
      if (!pendingNid || !pendingName) return;
      confirmBtn.disabled = true;
      setModalLoadingState(true);

      try {
        // Fetch CSRF token from Drupal session
        var csrfResp = await fetch('/session/token', { credentials: 'same-origin' });
        var csrfToken = (await csrfResp.text()).trim();

        var resp = await fetch('/crm/edit/ajax/delete', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': csrfToken
          },
          body: JSON.stringify({ nid: Number(pendingNid), type: 'contact', confirmation: pendingName })
        });

        var data = await resp.json();

        if (resp.ok && data.success) {
          // Remove row immediately from DOM (optimistic update already confirmed)
          var row = document.getElementById('contact-row-' + pendingNid);
          if (row) {
            row.style.transition = 'opacity .25s, transform .25s';
            row.style.opacity = '0';
            row.style.transform = 'translateX(12px)';
            setTimeout(function () { row.remove(); }, 260);
          }
          closeModal();
          // Show success notification via CRM toast
          if (window.CRM && window.CRM.toast) {
            window.CRM.toast('Contact "' + pendingName + '" deleted.', 'success', 4000);
          }
        } else {
          throw new Error(data.message || 'Delete failed');
        }
      } catch (err) {
        setModalLoadingState(false);
        confirmBtn.disabled = false;
        if (window.CRM && window.CRM.toast) {
          window.CRM.toast('Error: ' + err.message, 'error', 5000);
        } else {
          alert('Error: ' + err.message);
        }
      }
    });
  }

  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
  if (closeBtn) closeBtn.addEventListener('click', closeModal);
  if (overlay) overlay.addEventListener('click', closeModal);

  // Keyboard: Escape closes, Enter submits
  document.addEventListener('keydown', function (e) {
    if (!modal || modal.getAttribute('aria-hidden') === 'true') return;

    if (e.key === 'Escape') {
      e.preventDefault();
      closeModal();
      return;
    }

    if (e.key === 'Tab') {
      var focusables = getFocusableElements();
      if (!focusables.length) return;

      var first = focusables[0];
      var last = focusables[focusables.length - 1];

      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
      return;
    }

    if (e.key === 'Enter' && confirmBtn && !confirmBtn.disabled) {
      e.preventDefault();
      confirmBtn.click();
    }
  });

  // Wire up delete buttons in table
  document.querySelectorAll('.delete-btn').forEach(function (btn) {
    btn.setAttribute('aria-haspopup', 'dialog');
    btn.setAttribute('aria-expanded', 'false');
    btn.setAttribute('aria-controls', 'delete-modal');
    btn.addEventListener('click', function () {
      openModal(this.dataset.nid, this.dataset.name, this);
    });
  });
})();
</script>

{#
  crm-node-organization.html.twig
  Professional organization detail page — hero design matching contact page
#}
<style>body { background: #f0f2f5 !important; }</style>

<div class="crm-org-detail">

  {# ── Breadcrumb ───────────────────────────────────────────── #}
  <nav class="detail-breadcrumb">
    <a href="/crm/all-organizations"><i data-lucide="building-2"></i> Organizations</a>
    <i data-lucide="chevron-right"></i>
    <span>{{ title }}</span>
  </nav>

  {# ── Hero: cover gradient + avatar + identity ──────────────── #}
  <div class="contact-hero">
    <div class="org-cover"></div>

    <div class="contact-hero-body">

      {# Avatar — org logo or letter initial #}
      <div class="contact-avatar-section">
        {% if has_logo %}
          <div class="entity-avatar-icon org-avatar-icon">
            <img src="{{ logo_url }}" alt="{{ title }}">
          </div>
        {% else %}
          <div class="contact-avatar-placeholder org-avatar-placeholder">
            <span class="contact-avatar-initial">{{ initial }}</span>
          </div>
        {% endif %}
      </div>

      {# Identity #}
      <div class="contact-identity">
        <div class="contact-name-row">
          <h1 class="contact-name">{{ title }}</h1>
          {% if can_edit %}
            <button onclick="CRMInlineEdit.openModal({{ nid }}, 'organization')" class="contact-edit-btn">
              <i data-lucide="pencil" width="12" height="12"></i>Edit
            </button>
          {% endif %}
        </div>

        {% if industry or tags %}
          <div class="contact-roles">
            {% if industry %}
              <span class="contact-role-badge contact-role-badge-green">{{ industry }}</span>
            {% endif %}
            {% for tag in tags %}
              <span class="contact-role-badge">{{ tag }}</span>
            {% endfor %}
          </div>
        {% endif %}

        <div class="contact-meta-row">
          {% if website %}
            <a href="{{ website }}" target="_blank" rel="noopener noreferrer" class="contact-meta-chip contact-meta-link">
              <i data-lucide="globe" width="12" height="12"></i>{{ website_display ?: website }}
            </a>
          {% endif %}
          {% if employees_count %}
            <span class="contact-meta-chip">
              <i data-lucide="users" width="12" height="12"></i>{{ employees_count }} employees
            </span>
          {% endif %}
          {% if annual_revenue %}
            <span class="contact-meta-chip">
              <i data-lucide="bar-chart-2" width="12" height="12"></i>${{ annual_revenue|number_format(0) }} revenue
            </span>
          {% endif %}
          {% if staff_name %}
            <a href="{{ staff_url }}" class="contact-meta-chip contact-meta-link">
              <i data-lucide="user-check" width="12" height="12"></i>{{ staff_name }}
            </a>
          {% endif %}
        </div>
      </div>

      {# Quick-action buttons #}
      <div class="contact-quick-actions">
        <a href="/crm/add/contact" class="cqa-btn cqa-primary">
          <i data-lucide="user-plus" width="14" height="14"></i>Add Contact
        </a>
        <a href="/crm/add/deal" class="cqa-btn cqa-secondary">
          <i data-lucide="briefcase" width="14" height="14"></i>New Deal
        </a>
        {% if can_edit %}
          <button onclick="CRMInlineEdit.openModal({{ nid }}, 'organization')" class="cqa-btn cqa-secondary">
            <i data-lucide="edit-2" width="14" height="14"></i>Edit
          </button>
        {% endif %}
      </div>

    </div>
  </div>{# /.contact-hero #}

  {# ── Stats row ─────────────────────────────────────────────── #}
  <div class="cstats-grid">

    <div class="cstat-card cstat-blue">
      <div class="cstat-icon-wrap"><i data-lucide="users" width="20" height="20"></i></div>
      <div class="cstat-info">
        <div class="cstat-value">{{ contacts_count }}</div>
        <div class="cstat-label">Contacts</div>
      </div>
    </div>

    <div class="cstat-card cstat-purple">
      <div class="cstat-icon-wrap"><i data-lucide="trending-up" width="20" height="20"></i></div>
      <div class="cstat-info">
        <div class="cstat-value">{{ deals_count }}</div>
        <div class="cstat-label">Deals</div>
      </div>
    </div>

    {% if employees_count %}
      <div class="cstat-card cstat-green">
        <div class="cstat-icon-wrap"><i data-lucide="user-2" width="20" height="20"></i></div>
        <div class="cstat-info">
          <div class="cstat-value">{{ employees_count }}</div>
          <div class="cstat-label">Employees</div>
        </div>
      </div>
    {% else %}
      <div class="cstat-card cstat-green">
        <div class="cstat-icon-wrap"><i data-lucide="calendar" width="20" height="20"></i></div>
        <div class="cstat-info">
          <div class="cstat-value cstat-value-sm">{{ created|date('M j') }}</div>
          <div class="cstat-label">Created</div>
        </div>
      </div>
    {% endif %}

    {% if annual_revenue %}
      <div class="cstat-card cstat-amber">
        <div class="cstat-icon-wrap"><i data-lucide="dollar-sign" width="20" height="20"></i></div>
        <div class="cstat-info">
          <div class="cstat-value cstat-value-sm">${{ annual_revenue|number_format(0) }}</div>
          <div class="cstat-label">Annual Revenue</div>
        </div>
      </div>
    {% else %}
      <div class="cstat-card cstat-amber">
        <div class="cstat-icon-wrap"><i data-lucide="zap" width="20" height="20"></i></div>
        <div class="cstat-info">
          <div class="cstat-value cstat-value-sm">{{ industry ? industry : '—' }}</div>
          <div class="cstat-label">Industry</div>
        </div>
      </div>
    {% endif %}

  </div>{# /.cstats-grid #}

  {# ── Two-column content grid ───────────────────────────────── #}
  <div class="contact-content-grid">

    {# Left column: details + notes #}
    <div class="contact-col">

      <div class="ccontent-card">
        <div class="ccard-header">
          <div class="ccard-title">
            <i data-lucide="info" width="16" height="16"></i>
            <span>Organization Details</span>
          </div>
        </div>
        <div class="fields-grid detail-fields-grid">
          <div class="field-item">
            <div class="field-label">Organization Name</div>
            <div class="field-value">{{ title }}</div>
          </div>
          {% if industry %}
            <div class="field-item">
              <div class="field-label">Industry</div>
              <div class="field-value">{{ industry }}</div>
            </div>
          {% endif %}
          {% if website %}
            <div class="field-item">
              <div class="field-label">Website</div>
              <div class="field-value">
                <a href="{{ website }}" target="_blank" rel="noopener noreferrer">{{ website_display ?: website }}</a>
              </div>
            </div>
          {% endif %}
          {% if employees_count %}
            <div class="field-item">
              <div class="field-label">Employees</div>
              <div class="field-value">{{ employees_count }}</div>
            </div>
          {% endif %}
          {% if annual_revenue %}
            <div class="field-item">
              <div class="field-label">Annual Revenue</div>
              <div class="field-value amount">${{ annual_revenue|number_format(0) }}</div>
            </div>
          {% endif %}
          {% if staff_name %}
            <div class="field-item">
              <div class="field-label">Assigned Staff</div>
              <div class="field-value"><a href="{{ staff_url }}">{{ staff_name }}</a></div>
            </div>
          {% endif %}
          <div class="field-item">
            <div class="field-label">Created</div>
            <div class="field-value">{{ created|date('M j, Y') }}</div>
          </div>
          <div class="field-item">
            <div class="field-label">Last Updated</div>
            <div class="field-value">{{ changed|date('M j, Y') }}</div>
          </div>
        </div>
      </div>

      {% if notes %}
        <div class="notes-panel">
          <div class="notes-panel-label"><i data-lucide="file-text"></i> Notes</div>
          <div class="notes-panel-text">{{ notes }}</div>
        </div>
      {% endif %}

    </div>{# /.contact-col (left) #}

    {# Right column: contacts + deals #}
    <div class="contact-col">

      {# Contacts #}
      <div class="ccontent-card">
        <div class="ccard-header">
          <div class="ccard-title">
            <i data-lucide="users" width="16" height="16"></i>
            <span>Contacts</span>
            {% if contacts_count > contacts|length %}
              <span class="detail-subtle-count">({{ contacts|length }} of {{ contacts_count }})</span>
            {% endif %}
          </div>
          <a href="/crm/all-contacts" class="cview-all-link">
            View all<i data-lucide="arrow-right" width="13" height="13"></i>
          </a>
        </div>
        {% if contacts %}
          <div class="ctimeline-list">
            {% for contact in contacts %}
              <a href="{{ contact.url }}" class="ctl-item">
                <div class="ctl-dot dot-blue"></div>
                <div class="ctl-body">
                  <div class="ctl-title">{{ contact.title }}</div>
                  <div class="ctl-meta">
                    {% if contact.position %}
                      <span class="ctl-chip chip-blue">{{ contact.position }}</span>
                    {% endif %}
                    {% if contact.email %}
                      <span class="ctl-date">{{ contact.email }}</span>
                    {% endif %}
                  </div>
                </div>
                <i data-lucide="chevron-right" class="ctl-arrow" width="13" height="13"></i>
              </a>
            {% endfor %}
          </div>
        {% else %}
          <div class="empty-state detail-empty-state">
            <i data-lucide="users"></i>
            <p>No contacts yet</p>
            <a href="/crm/add/contact" class="cqa-btn cqa-primary detail-empty-action">Add Contact</a>
          </div>
        {% endif %}
      </div>

      {# Deals #}
      <div class="ccontent-card">
        <div class="ccard-header">
          <div class="ccard-title">
            <i data-lucide="trending-up" width="16" height="16"></i>
            <span>Deals</span>
          </div>
          <a href="/crm/all-deals" class="cview-all-link">
            View all<i data-lucide="arrow-right" width="13" height="13"></i>
          </a>
        </div>
        {% if active_deals %}
          <div class="ctimeline-list">
            {% for deal in active_deals %}
              <a href="{{ deal.url }}" class="ctl-item">
                <div class="ctl-dot dot-purple"></div>
                <div class="ctl-body">
                  <div class="ctl-title">{{ deal.title }}</div>
                  <div class="ctl-meta">
                    {% if deal.stage %}
                      <span class="ctl-chip chip-purple">{{ deal.stage }}</span>
                    {% endif %}
                    {% if deal.amount %}
                      <span class="ctl-value">${{ deal.amount }}</span>
                    {% endif %}
                  </div>
                </div>
                <i data-lucide="chevron-right" class="ctl-arrow" width="13" height="13"></i>
              </a>
            {% endfor %}
          </div>
        {% else %}
          <div class="empty-state detail-empty-state">
            <i data-lucide="trending-up"></i>
            <p>No deals yet</p>
            <a href="/crm/add/deal" class="cqa-btn cqa-primary detail-empty-action">Add Deal</a>
          </div>
        {% endif %}
      </div>

    </div>{# /.contact-col (right) #}

  </div>{# /.contact-content-grid #}

</div>{# /.crm-org-detail #}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.lucide) { lucide.createIcons(); }
  });
</script>

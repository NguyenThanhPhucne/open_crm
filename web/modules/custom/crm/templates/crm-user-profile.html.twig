{{ attach_library('crm/user_profile_styles') }}

<div class="crm-user-profile">

  {# ── Cover + Floating Avatar Hero ─────────────────────────── #}
  <div class="profile-hero">
    <div class="profile-cover"></div>

    <div class="profile-hero-body">
      {# Avatar section #}
      <div class="profile-avatar-section">
        {% if has_picture %}
          <img src="{{ user_picture_url }}" alt="{{ user_name }}" class="profile-avatar">
        {% else %}
          <div class="profile-avatar profile-avatar-placeholder">
            <span class="avatar-initial">{{ user_initial }}</span>
          </div>
        {% endif %}
        <span class="avatar-status online" title="Active"></span>
      </div>

      {# Identity #}
      <div class="profile-identity">
        <div class="profile-name-row">
          <h1 class="profile-name">{{ user_name }}</h1>
          {% if is_own_profile %}
            <a href="/user/{{ user.id }}/edit" class="btn-edit-inline">
              <i data-lucide="pencil" width="12" height="12"></i>Edit
            </a>
          {% endif %}
        </div>

        {% if role_names %}
          <div class="profile-roles">
            {% for role in role_names %}
              <span class="role-badge role-badge-{{ role|lower|replace({' ': '-'}) }}">{{ role }}</span>
            {% endfor %}
          </div>
        {% endif %}

        <div class="profile-meta-row">
          {% if team_name %}
            <span class="meta-chip"><i data-lucide="users" width="12" height="12"></i>{{ team_name }}</span>
          {% endif %}
          <span class="meta-chip"><i data-lucide="mail" width="12" height="12"></i>{{ user_email }}</span>
          <span class="meta-chip"><i data-lucide="calendar" width="12" height="12"></i>Joined {{ user_created|date('M Y') }}</span>
        </div>
      </div>

      {# Quick-add buttons (own profile only) #}
      {% if is_own_profile %}
        <div class="profile-quick-actions">
          <a href="/crm/add/deal" class="qa-btn qa-primary">
            <i data-lucide="plus" width="14" height="14"></i>New Deal
          </a>
          <a href="/crm/add/contact" class="qa-btn qa-secondary">
            <i data-lucide="user-plus" width="14" height="14"></i>Contact
          </a>
          <a href="/crm/add/activity" class="qa-btn qa-secondary">
            <i data-lucide="calendar-plus" width="14" height="14"></i>Activity
          </a>
        </div>
      {% endif %}
    </div>
  </div>

  {# ── Stats row ─────────────────────────────────────────────── #}
  <div class="stats-grid">
    <a href="/crm/my-contacts" class="stat-card stat-blue">
      <div class="stat-icon-wrap"><i data-lucide="users" width="20" height="20"></i></div>
      <div class="stat-info">
        <div class="stat-value" data-count="{{ stats.contacts }}">{{ stats.contacts }}</div>
        <div class="stat-label">Contacts</div>
      </div>
      <i data-lucide="chevron-right" class="stat-arrow" width="16" height="16"></i>
    </a>

    <a href="/crm/my-deals" class="stat-card stat-purple">
      <div class="stat-icon-wrap"><i data-lucide="briefcase" width="20" height="20"></i></div>
      <div class="stat-info">
        <div class="stat-value" data-count="{{ stats.deals }}">{{ stats.deals }}</div>
        <div class="stat-label">Deals</div>
        {% if stats.total_value_formatted %}
          <div class="stat-sub">{{ stats.total_value_formatted }}</div>
        {% endif %}
      </div>
      <i data-lucide="chevron-right" class="stat-arrow" width="16" height="16"></i>
    </a>

    <a href="/crm/my-organizations" class="stat-card stat-green">
      <div class="stat-icon-wrap"><i data-lucide="building" width="20" height="20"></i></div>
      <div class="stat-info">
        <div class="stat-value" data-count="{{ stats.organizations }}">{{ stats.organizations }}</div>
        <div class="stat-label">Organizations</div>
      </div>
      <i data-lucide="chevron-right" class="stat-arrow" width="16" height="16"></i>
    </a>

    <a href="/crm/my-activities" class="stat-card stat-amber">
      <div class="stat-icon-wrap"><i data-lucide="check-circle" width="20" height="20"></i></div>
      <div class="stat-info">
        <div class="stat-value" data-count="{{ stats.activities }}">{{ stats.activities }}</div>
        <div class="stat-label">Activities</div>
      </div>
      <i data-lucide="chevron-right" class="stat-arrow" width="16" height="16"></i>
    </a>
  </div>

  {# ── Content grid ──────────────────────────────────────────── #}
  <div class="content-grid">

    {# Recent Activities #}
    <div class="content-card">
      <div class="card-header">
        <div class="card-title">
          <i data-lucide="activity" width="17" height="17"></i>
          <span>Recent Activities</span>
        </div>
        <a href="/crm/my-activities" class="view-all-link">
          View all<i data-lucide="arrow-right" width="14" height="14"></i>
        </a>
      </div>

      {% if recent_activities %}
        <div class="timeline-list">
          {% for activity in recent_activities %}
            <a href="{{ activity.url }}" class="tl-item">
              <div class="tl-dot dot-blue"></div>
              <div class="tl-body">
                <div class="tl-title">{{ activity.title }}</div>
                <div class="tl-meta">
                  {% if activity.type %}
                    <span class="tl-chip chip-blue">{{ activity.type }}</span>
                  {% endif %}
                  {% if activity.date %}
                    <span class="tl-date"><i data-lucide="clock" width="10" height="10"></i>{{ activity.date|date('d M Y') }}</span>
                  {% endif %}
                </div>
              </div>
              <i data-lucide="chevron-right" class="tl-arrow" width="13" height="13"></i>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i data-lucide="calendar-x" width="32" height="32"></i>
          <p>No activities yet</p>
          <a href="/crm/add/activity" class="qa-btn qa-primary" style="margin-top:6px">Add Activity</a>
        </div>
      {% endif %}
    </div>

    {# Recent Deals #}
    <div class="content-card">
      <div class="card-header">
        <div class="card-title">
          <i data-lucide="trending-up" width="17" height="17"></i>
          <span>Recent Deals</span>
        </div>
        <a href="/crm/my-deals" class="view-all-link">
          View all<i data-lucide="arrow-right" width="14" height="14"></i>
        </a>
      </div>

      {% if recent_deals %}
        <div class="timeline-list">
          {% for deal in recent_deals %}
            <a href="{{ deal.url }}" class="tl-item">
              <div class="tl-dot dot-purple"></div>
              <div class="tl-body">
                <div class="tl-title">{{ deal.title }}</div>
                <div class="tl-meta">
                  {% if deal.stage %}
                    <span class="tl-chip chip-purple">{{ deal.stage }}</span>
                  {% endif %}
                  {% if deal.value %}
                    <span class="tl-value">{{ deal.value }}</span>
                  {% endif %}
                </div>
              </div>
              <i data-lucide="chevron-right" class="tl-arrow" width="13" height="13"></i>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-state">
          <i data-lucide="briefcase" width="32" height="32"></i>
          <p>No deals yet</p>
          <a href="/crm/add/deal" class="qa-btn qa-primary" style="margin-top:6px">Add Deal</a>
        </div>
      {% endif %}
    </div>

  </div>
</div>

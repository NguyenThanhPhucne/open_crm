<div class="crm-user-profile">
  <!-- Profile Header Card -->
  <div class="profile-header-card">
    <div class="profile-avatar-wrapper">
      {% if has_picture %}
        <img src="{{ user_picture_url }}" alt="{{ user_name }}" class="profile-avatar">
      {% else %}
        <div class="profile-avatar profile-avatar-placeholder">
          <span class="avatar-initial">{{ user_initial }}</span>
        </div>
      {% endif %}
    </div>
    
    <div class="profile-header-content">
      <div class="profile-main-info">
        <h1 class="profile-name">{{ user_name }}</h1>
        
        {% if role_names %}
          <div class="profile-roles">
            {% for role in role_names %}
              <span class="role-badge role-badge-{{ role|lower|replace({' ': '-'}) }}">{{ role }}</span>
            {% endfor %}
          </div>
        {% endif %}
      </div>
      
      <div class="profile-metadata">
        {% if team_name %}
          <div class="metadata-item">
            <i data-lucide="users" width="18" height="18"></i>
            <span>{{ team_name }}</span>
          </div>
        {% endif %}
        
        <div class="metadata-item">
          <i data-lucide="mail" width="18" height="18"></i>
          <span>{{ user_email }}</span>
        </div>
        
        <div class="metadata-item">
          <i data-lucide="calendar" width="18" height="18"></i>
          <span>Member since {{ user_created|date('M d, Y') }}</span>
        </div>
      </div>
      
      {% if is_own_profile %}
        <div class="profile-actions">
          <a href="/user/{{ user.id }}/edit" class="btn btn-primary">
            <i data-lucide="pencil" width="18" height="18"></i>
            <span>Edit Profile</span>
          </a>
          <a href="/user/{{ user.id }}/edit" class="btn btn-secondary">
            <i data-lucide="camera" width="18" height="18"></i>
            <span>Change Photo</span>
          </a>
        </div>
      {% endif %}
    </div>
  </div>
  
  <!-- Statistics Cards Grid -->
  <div class="stats-grid">
    <div class="stat-card stat-card-blue">
      <div class="stat-icon-wrapper">
        <i data-lucide="users" width="20" height="20"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.contacts }}</div>
        <div class="stat-label">Contacts</div>
      </div>
    </div>
    
    <div class="stat-card stat-card-purple">
      <div class="stat-icon-wrapper">
        <i data-lucide="briefcase" width="20" height="20"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.deals }}</div>
        <div class="stat-label">Deals</div>
      </div>
    </div>
    
    <div class="stat-card stat-card-green">
      <div class="stat-icon-wrapper">
        <i data-lucide="building" width="20" height="20"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.organizations }}</div>
        <div class="stat-label">Organizations</div>
      </div>
    </div>
    
    <div class="stat-card stat-card-orange">
      <div class="stat-icon-wrapper">
        <i data-lucide="check-circle" width="20" height="20"></i>
      </div>
      <div class="stat-info">
        <div class="stat-value">{{ stats.activities }}</div>
        <div class="stat-label">Activities</div>
      </div>
    </div>
  </div>
  
  <!-- Content Grid: Activities & Deals -->
  <div class="content-grid">
    <!-- Recent Activities Card -->
    {% if recent_activities %}
      <div class="content-card">
        <div class="card-header">
          <div class="card-title">
            <i data-lucide="activity" width="20" height="20"></i>
            <span>Recent Activities</span>
          </div>
          <a href="/crm/my-activities" class="view-all-link">
            <span>View all</span>
            <i data-lucide="arrow-right" width="16" height="16"></i>
          </a>
        </div>
        
        <div class="activity-list">
          {% for activity in recent_activities %}
            <div class="activity-item">
              <div class="activity-icon">
                <i data-lucide="calendar-check" width="18" height="18"></i>
              </div>
              <div class="activity-content">
                <a href="{{ activity.url }}" class="activity-title">{{ activity.title }}</a>
                <div class="activity-meta">
                  <span class="activity-type">{{ activity.type }}</span>
                  {% if activity.date %}
                    <span class="activity-separator">•</span>
                    <span class="activity-date">{{ activity.date|date('M d, Y') }}</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
    
    <!-- Recent Deals Card -->
    {% if recent_deals %}
      <div class="content-card">
        <div class="card-header">
          <div class="card-title">
            <i data-lucide="trending-up" width="20" height="20"></i>
            <span>Recent Deals</span>
          </div>
          <a href="/crm/my-deals" class="view-all-link">
            <span>View all</span>
            <i data-lucide="arrow-right" width="16" height="16"></i>
          </a>
        </div>
        
        <div class="deal-list">
          {% for deal in recent_deals %}
            <div class="deal-item">
              <div class="deal-icon">
                <i data-lucide="briefcase" width="18" height="18"></i>
              </div>
              <div class="deal-content">
                <a href="{{ deal.url }}" class="deal-title">{{ deal.title }}</a>
                <div class="deal-meta">
                  {% if deal.stage %}
                    <span class="deal-stage">{{ deal.stage }}</span>
                  {% endif %}
                  {% if deal.value %}
                    <span class="deal-separator">•</span>
                    <span class="deal-value">{{ deal.value }} VND</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

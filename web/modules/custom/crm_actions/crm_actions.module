<?php

/**
 * @file
 * CRM Global Actions module.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Component\Utility\Html;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_help().
 */
function crm_actions_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.crm_actions':
      return '<p>' . t('Provides global navigation and quick actions for CRM.') . '</p>';
  }
}

/**
 * Implements hook_page_top().
 */
function crm_actions_page_top(array &$page_top) {
  $current_user = \Drupal::currentUser();
  
  // Only show for authenticated users
  if ($current_user->isAuthenticated()) {
    $current_path = \Drupal::request()->getRequestUri();
    
    // Show on CRM pages
    if (str_contains($current_path, '/crm/') || 
        str_contains($current_path, '/node/') ||
        str_contains($current_path, '/app/')) {
      
      $page_top['crm_global_nav'] = [
        '#markup' => Markup::create(_crm_actions_build_navbar()),
        '#attached' => [
          'library' => [
            'crm_actions/global_nav',
          ],
        ],
        '#cache' => [
          'contexts' => ['url.path', 'user'],
        ],
      ];
    }
  }
}

/**
 * Build global CRM navigation bar.
 */
function _crm_actions_build_navbar() {
  $current_path = \Drupal::request()->getRequestUri();
  
  $items = [
    [
      'url' => '/crm/dashboard',
      'label' => 'Dashboard',
      'icon' => 'layout-dashboard',
      'active' => str_contains($current_path, '/crm/dashboard'),
    ],
    [
      'url' => '/crm/my-contacts',
      'label' => 'Contacts',
      'icon' => 'users',
      'active' => str_contains($current_path, '/crm/my-contacts') || str_contains($current_path, '/node/add/contact'),
    ],
    [
      'url' => '/crm/my-deals',
      'label' => 'Deals',
      'icon' => 'briefcase',
      'active' => str_contains($current_path, '/crm/my-deals'),
    ],
    [
      'url' => '/crm/pipeline',
      'label' => 'Pipeline',
      'icon' => 'kanban-square',
      'active' => str_contains($current_path, '/crm/pipeline'),
    ],
    [
      'url' => '/crm/my-activities',
      'label' => 'Activities',
      'icon' => 'activity',
      'active' => str_contains($current_path, '/crm/my-activities'),
    ],
    [
      'url' => '/app/organizations',
      'label' => 'Organizations',
      'icon' => 'building-2',
      'active' => str_contains($current_path, '/app/organizations'),
    ],
  ];
  
  $nav_html = '<div class="crm-global-nav">';
  $nav_html .= '<div class="crm-nav-container">';
  $nav_html .= '<div class="crm-nav-brand">';
  $nav_html .= '<i data-lucide="zap" width="24" height="24" style="color: #3b82f6;"></i>';
  $nav_html .= '<span>OpenCRM</span>';
  $nav_html .= '</div>';
  $nav_html .= '<div class="crm-nav-items">';
  
  foreach ($items as $item) {
    $active_class = $item['active'] ? ' active' : '';
    $nav_html .= '<a href="' . $item['url'] . '" class="crm-nav-item' . $active_class . '">';
    $nav_html .= '<i data-lucide="' . $item['icon'] . '" width="18" height="18"></i>';
    $nav_html .= '<span>' . $item['label'] . '</span>';
    $nav_html .= '</a>';
  }
  
  $nav_html .= '</div>';
  $nav_html .= '</div>';
  $nav_html .= '</div>';
  
  return $nav_html;
}

/**
 * Implements hook_preprocess_views_view().
 */
function crm_actions_preprocess_views_view(&$variables) {
  $view = $variables['view'];
  $view_id = $view->id();
  
  // Attach our styling library to specific views
  if (in_array($view_id, ['all_organizations', 'my_activities', 'my_contacts', 'my_deals', 'my_organizations'])) {
    $variables['#attached']['library'][] = 'crm_actions/global_nav';
  }
}

<?php

/**
 * @file
 * CRM Global Actions module.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Component\Utility\Html;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_help().
 */
function crm_actions_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.crm_actions':
      return '<p>' . t('Provides global navigation and quick actions for CRM.') . '</p>';
  }
}

/**
 * Implements hook_page_top().
 */
function crm_actions_page_top(array &$page_top) {
  $current_user = \Drupal::currentUser();

  // Only show the nav bar to authenticated users.
  if ($current_user->isAnonymous()) {
    return;
  }

  $current_path = \Drupal::request()->getRequestUri();

  if ($current_path === '/' ||
      str_contains($current_path, '/crm/') ||
      str_contains($current_path, '/user/') ||
      str_contains($current_path, '/node/') ||
      str_contains($current_path, '/app/')) {

    $page_top['crm_global_nav'] = [
      '#markup' => Markup::create(_crm_actions_build_navbar()),
      '#attached' => [
        'library' => [
          'crm_actions/global_nav',
        ],
      ],
      '#cache' => [
        'contexts' => ['url.path', 'user'],
      ],
    ];
  }
}

/**
 * Build global CRM navigation bar.
 */
function _crm_actions_build_navbar() {
  $current_path = \Drupal::request()->getRequestUri();
  $current_user = \Drupal::currentUser();
  
  // Check user role level.
  $is_anonymous = $current_user->isAnonymous();
  $is_admin     = $current_user->hasRole('administrator');
  $is_manager   = in_array('sales_manager', $current_user->getRoles());
  // Admins and managers both see the all-* versions of the nav links.
  $is_admin = $is_admin || $is_manager;

  // Navigation items — anonymous sees all-* pages (same data as my-* since they see all published records).
  $items = [
    [
      'url' => '/crm/dashboard',
      'label' => 'Dashboard',
      'icon' => 'layout-dashboard',
      'active' => str_contains($current_path, '/crm/dashboard'),
    ],
    [
      'url' => $is_admin ? '/crm/all-contacts' : '/crm/my-contacts',
      'label' => $is_admin ? 'All Contacts' : 'Contacts',
      'icon' => 'users',
      'active' => str_contains($current_path, '/crm/my-contacts') ||
                  str_contains($current_path, '/crm/all-contacts') ||
                  str_contains($current_path, '/crm/add/contact'),
    ],
    [
      'url' => $is_admin ? '/crm/all-deals' : '/crm/my-deals',
      'label' => $is_admin ? 'All Deals' : 'Deals',
      'icon' => 'briefcase',
      'active' => str_contains($current_path, '/crm/my-deals') || str_contains($current_path, '/crm/all-deals'),
    ],
    [
      'url' => $is_admin ? '/crm/all-pipeline' : '/crm/my-pipeline',
      'label' => $is_admin ? 'All Pipeline' : 'Pipeline',
      'icon' => 'kanban-square',
      'active' => str_contains($current_path, '/crm/my-pipeline') || str_contains($current_path, '/crm/all-pipeline'),
    ],
    [
      'url' => $is_admin ? '/crm/all-activities' : '/crm/my-activities',
      'label' => $is_admin ? 'All Activities' : 'Activities',
      'icon' => 'activity',
      'active' => str_contains($current_path, '/crm/my-activities') || str_contains($current_path, '/crm/all-activities'),
    ],
    [
      'url' => $is_admin ? '/crm/all-organizations' : '/crm/my-organizations',
      'label' => $is_admin ? 'All Organizations' : 'Organizations',
      'icon' => 'building-2',
      'active' => str_contains($current_path, '/crm/my-organizations') || str_contains($current_path, '/crm/all-organizations'),
    ],
  ];

  $nav_html = '<div class="crm-global-nav">';
  $nav_html .= '<div class="crm-nav-container">';
  $nav_html .= '<a href="/crm/dashboard" class="crm-nav-brand" title="Go to Dashboard" aria-label="OpenCRM Home">';
  $nav_html .= '<i data-lucide="zap" width="24" height="24" style="color: #3b82f6;"></i>';
  $nav_html .= '<span>OpenCRM</span>';
  $nav_html .= '</a>';
  $nav_html .= '<div class="crm-nav-items">';

  foreach ($items as $item) {
    $active_class = $item['active'] ? ' active' : '';
    $nav_html .= '<a href="' . $item['url'] . '" class="crm-nav-item' . $active_class . '">';
    $nav_html .= '<i data-lucide="' . $item['icon'] . '" width="18" height="18"></i>';
    $nav_html .= '<span>' . $item['label'] . '</span>';
    $nav_html .= '</a>';
  }

  $nav_html .= '</div>';

  // Right side: show user info for authenticated users.
  $nav_html .= '<div class="crm-nav-right">';
  if ($is_anonymous) {
    // This branch is no longer reachable — hook_page_top guards anonymous out.
    $nav_html .= '<a href="/login" class="crm-login-btn">';
    $nav_html .= '<i data-lucide="log-in" width="14" height="14"></i><span>Login</span></a>';
  }
  $nav_html .= '</div>';

  $nav_html .= '</div>';
  $nav_html .= '</div>';

  return $nav_html;
}

/**
 * Implements hook_preprocess_page().
 *
 * Removes the Gin sticky header region (region-sticky) from all CRM pages.
 * The sticky bar is not needed since CRM has its own custom navigation.
 * We suppress gin_form_actions so the <header class="region region-sticky">
 * renders empty and the CSS display:none rule hides it cleanly.
 */
function crm_actions_preprocess_page(&$variables) {
  // Unset Gin form-actions variables so the sticky bar has no content.
  $variables['gin_form_actions'] = '';
  $variables['gin_form_actions_class'] = '';

  // Also unset local actions from the sticky bar position.
  // They will still render in page.content via the normal content region.
  unset($variables['page']['header']['gin_primary_local_tasks']);
}

/**
 * Implements hook_preprocess_views_view().
 */
function crm_actions_preprocess_views_view(&$variables) {
  $view = $variables['view'];
  $view_id = $view->id();
  
  // Attach our styling library to specific views
  if (in_array($view_id, ['all_organizations', 'my_activities', 'my_contacts', 'my_deals', 'my_organizations'])) {
    $variables['#attached']['library'][] = 'crm_actions/global_nav';
  }
}

<div class="activity-modal-wrapper">
  <div class="activity-form-container">
    <div class="activity-form-header">
      <h2>
        <i data-lucide="phone"></i>
        Log Call with {{ contact_name }}
      </h2>
      <button class="activity-close" onclick="window.history.back()">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="log-call-form" class="activity-form">
      <input type="hidden" name="contact_id" value="{{ contact_id }}">

      <div class="form-group">
        <label for="call-outcome" class="required">Call Outcome</label>
        <select id="call-outcome" name="outcome" required>
          <option value="">-- Select outcome --</option>
          <option value="Answered - Interested">Answered - Interested</option>
          <option value="Answered - Not Interested">Answered - Not Interested</option>
          <option value="Answered - Declined">Answered - Declined</option>
          <option value="No Answer">No Answer</option>
          <option value="Busy / Unavailable">Busy / Unavailable</option>
          <option value="Scheduled Callback">Scheduled Callback</option>
          <option value="Meeting Scheduled">Meeting Scheduled</option>
        </select>
      </div>

      <div class="form-group">
        <label for="call-notes">Call Notes</label>
        <textarea 
          id="call-notes" 
          name="notes" 
          rows="6" 
          placeholder="Note the call content, customer needs, follow-up items..."></textarea>
      </div>

      <div class="form-group">
        <label for="call-deal">Related Deal (if any)</label>
        <select id="call-deal" name="deal">
          <option value="">-- No deal --</option>
          <!-- Deals will be loaded via JS -->
        </select>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="window.history.back()">Cancel</button>
        <button type="submit" class="btn-primary">
          <i data-lucide="save"></i>
          Save Call
        </button>
      </div>

      <div id="activity-message" class="alert" style="display:none;"></div>
    </form>
  </div>
</div>

<!-- Load deals for dropdown -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const contactId = {{ contact_id }};
    const dealSelect = document.getElementById('call-deal');
    
    // Fetch deals related to this contact
    fetch('/jsonapi/node/deal?filter[field_related_contact.id]=' + contactId + '&sort=-created')
      .then(response => response.json())
      .then(data => {
        if (data.data && data.data.length > 0) {
          data.data.forEach(deal => {
            const option = document.createElement('option');
            option.value = deal.id;
            option.textContent = deal.attributes.title;
            dealSelect.appendChild(option);
          });
        }
      })
      .catch(error => console.error('Error loading deals:', error));
  });
</script>

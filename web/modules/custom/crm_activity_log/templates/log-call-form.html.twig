<div class="activity-modal-wrapper">
  <div class="activity-form-container">
    <div class="activity-form-header">
      <h2>
        <i data-lucide="phone"></i>
        Log Call với {{ contact_name }}
      </h2>
      <button class="activity-close" onclick="window.history.back()">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="log-call-form" class="activity-form">
      <input type="hidden" name="contact_id" value="{{ contact_id }}">

      <div class="form-group">
        <label for="call-outcome" class="required">Kết quả cuộc gọi</label>
        <select id="call-outcome" name="outcome" required>
          <option value="">-- Chọn kết quả --</option>
          <option value="Khách nghe máy - Quan tâm">✅ Khách nghe máy - Quan tâm</option>
          <option value="Khách nghe máy - Chưa quan tâm">⚠️ Khách nghe máy - Chưa quan tâm</option>
          <option value="Khách nghe máy - Từ chối">❌ Khách nghe máy - Từ chối</option>
          <option value="Không nghe máy">📵 Không nghe máy</option>
          <option value="Thuê bao / Máy bận">📞 Thuê bao / Máy bận</option>
          <option value="Hẹn gọi lại sau">🔄 Hẹn gọi lại sau</option>
          <option value="Đặt lịch meeting">📅 Đặt lịch meeting</option>
        </select>
      </div>

      <div class="form-group">
        <label for="call-notes">Ghi chú cuộc gọi</label>
        <textarea 
          id="call-notes" 
          name="notes" 
          rows="6" 
          placeholder="Ghi chú nội dung cuộc gọi, nhu cầu khách hàng, điều cần follow-up..."></textarea>
      </div>

      <div class="form-group">
        <label for="call-deal">Deal liên quan (nếu có)</label>
        <select id="call-deal" name="deal">
          <option value="">-- Không có deal --</option>
          <!-- Deals will be loaded via JS -->
        </select>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="window.history.back()">Hủy</button>
        <button type="submit" class="btn-primary">
          <i data-lucide="save"></i>
          Lưu cuộc gọi
        </button>
      </div>

      <div id="activity-message" class="alert" style="display:none;"></div>
    </form>
  </div>
</div>

<!-- Load deals for dropdown -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const contactId = {{ contact_id }};
    const dealSelect = document.getElementById('call-deal');
    
    // Fetch deals related to this contact
    fetch('/jsonapi/node/deal?filter[field_related_contact.id]=' + contactId + '&sort=-created')
      .then(response => response.json())
      .then(data => {
        if (data.data && data.data.length > 0) {
          data.data.forEach(deal => {
            const option = document.createElement('option');
            option.value = deal.id;
            option.textContent = deal.attributes.title;
            dealSelect.appendChild(option);
          });
        }
      })
      .catch(error => console.error('Error loading deals:', error));
  });
</script>

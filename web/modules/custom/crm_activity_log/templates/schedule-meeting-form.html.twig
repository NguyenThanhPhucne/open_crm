<div class="activity-modal-wrapper">
  <div class="activity-form-container">
    <div class="activity-form-header">
      <h2>
        <i data-lucide="calendar-plus"></i>
        Schedule Meeting with {{ contact_name }}
      </h2>
      <button class="activity-close" onclick="window.history.back()">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="schedule-meeting-form" class="activity-form">
      <input type="hidden" name="contact_id" value="{{ contact_id }}">

      <div class="form-group">
        <label for="meeting-title" class="required">Meeting Title</label>
        <input 
          type="text" 
          id="meeting-title" 
          name="title" 
          required 
          placeholder="e.g. Product Demo Meeting">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="meeting-date" class="required">Date</label>
          <input type="date" id="meeting-date" name="meeting_date" required>
        </div>
        <div class="form-group">
          <label for="meeting-time" class="required">Time</label>
          <input type="time" id="meeting-time" name="meeting_time" required value="14:00">
        </div>
      </div>

      <div class="form-group">
        <label for="meeting-agenda">Agenda</label>
        <textarea 
          id="meeting-agenda" 
          name="agenda" 
          rows="5" 
          placeholder="Meeting agenda, topics to discuss, materials to prepare..."></textarea>
      </div>

      <div class="form-group">
        <label for="meeting-deal">Related Deal (if any)</label>
        <select id="meeting-deal" name="deal">
          <option value="">-- No deal --</option>
          <!-- Deals will be loaded via JS -->
        </select>
      </div>

      <div class="info-box">
        <i data-lucide="info"></i>
        <div>
          <strong>Note:</strong> Once scheduled, this meeting will appear in your calendar and you will receive a reminder notification.
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="window.history.back()">Cancel</button>
        <button type="submit" class="btn-primary">
          <i data-lucide="calendar-check"></i>
          Schedule
        </button>
      </div>

      <div id="activity-message" class="alert" style="display:none;"></div>
    </form>
  </div>
</div>

<!-- Load deals for dropdown -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const contactId = {{ contact_id }};
    const dealSelect = document.getElementById('meeting-deal');
    
    // Set default date to tomorrow
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    document.getElementById('meeting-date').valueAsDate = tomorrow;
    
    // Fetch deals related to this contact
    fetch('/jsonapi/node/deal?filter[field_related_contact.id]=' + contactId + '&sort=-created')
      .then(response => response.json())
      .then(data => {
        if (data.data && data.data.length > 0) {
          data.data.forEach(deal => {
            const option = document.createElement('option');
            option.value = deal.id;
            option.textContent = deal.attributes.title;
            dealSelect.appendChild(option);
          });
        }
      })
      .catch(error => console.error('Error loading deals:', error));
  });
</script>

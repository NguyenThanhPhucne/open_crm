{#
/**
 * @file
 * Professional Conversations Management Template (Lucide icons only).
 *
 * Available variables:
 * - conversations: Array of conversation objects with enriched data
 * - stats: Summary statistics
 */
#}

{% import '@chat_api/_icons.html.twig' as icons %}

<div class="chat-admin-conversations">
  {# Page Header #}
  <div class="page-header">
    <div>
      <h1>{{ icons.icon_message_square('icon-inline') }} {{ 'Conversation Management'|t }}</h1>
      <p class="subtitle">{{ 'View and monitor all chat conversations'|t }}</p>
    </div>
    <div class="header-actions">
      <a href="/admin/chat" class="btn btn-secondary">
        {{ icons.icon_arrow_left('icon-inline') }} {{ 'Back to Dashboard'|t }}
      </a>
    </div>
  </div>

  {# Summary Statistics #}
  <div class="users-stats">
    <div class="stat-box">
      {{ icons.icon_message_square('stat-icon') }}
      <div class="stat-content">
        <div class="stat-value">{{ stats.total_conversations }}</div>
        <div class="stat-label">{{ 'Total Conversations'|t }}</div>
      </div>
    </div>
    <div class="stat-box">
      {{ icons.icon_users('stat-icon stat-icon--success') }}
      <div class="stat-content">
        <div class="stat-value">{{ stats.private_conversations }}</div>
        <div class="stat-label">{{ 'Private Chats'|t }}</div>
      </div>
    </div>
    <div class="stat-box">
      {{ icons.icon_users('stat-icon stat-icon--info') }}
      <div class="stat-content">
        <div class="stat-value">{{ stats.group_conversations }}</div>
        <div class="stat-label">{{ 'Group Chats'|t }}</div>
      </div>
    </div>
    <div class="stat-box">
      {{ icons.icon_alert_circle('stat-icon stat-icon--danger') }}
      <div class="stat-content">
        <div class="stat-value">{{ stats.active_today }}</div>
        <div class="stat-label">{{ 'Active Today'|t }}</div>
      </div>
    </div>
  </div>

  {# Conversations Table #}
  <div class="table-container">
    <div class="table-header">
      <h2>{{ icons.icon_list('icon-inline') }} {{ 'All Conversations'|t }}</h2>
      <div class="table-actions">
        <div class="search-box">
          {{ icons.icon_search('icon-inline') }}
          <input type="text" id="conversationSearch" placeholder="{{ 'Search conversations...'|t }}">
        </div>
        <select id="typeFilter" class="filter-select">
          <option value="all">{{ 'All Types'|t }}</option>
          <option value="private">{{ 'Private Only'|t }}</option>
          <option value="group">{{ 'Group Only'|t }}</option>
        </select>
      </div>
    </div>

    {% if conversations|length > 0 %}
      <div class="table-responsive">
        <table class="users-table conversations-table">
          <thead>
            <tr>
              <th>{{ icons.icon_info('icon-inline') }} {{ 'ID'|t }}</th>
              <th>{{ icons.icon_message_square('icon-inline') }} {{ 'Conversation'|t }}</th>
              <th>{{ icons.icon_list('icon-inline') }} {{ 'Type'|t }}</th>
              <th>{{ icons.icon_users('icon-inline') }} {{ 'Participants'|t }}</th>
              <th>{{ icons.icon_message_square('icon-inline') }} {{ 'Last Message'|t }}</th>
              <th>{{ icons.icon_mail('icon-inline') }} {{ 'Messages'|t }}</th>
              <th>{{ icons.icon_calendar('icon-inline') }} {{ 'Created'|t }}</th>
              <th>{{ icons.icon_clock('icon-inline') }} {{ 'Last Activity'|t }}</th>
              <th>{{ icons.icon_more_vertical('icon-inline') }} {{ 'Actions'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for conversation in conversations %}
              <tr class="conversation-row" data-type="{{ conversation.type }}" data-id="{{ conversation._id }}">
                <td class="conversation-id">
                  <strong>#{{ conversation.id }}</strong>
                </td>
                <td class="conversation-info">
                  {% if conversation.type == 'group' %}
                    <div class="conversation-avatar">
                      {{ icons.icon_users('icon-inline') }}
                    </div>
                    <div class="conversation-details">
                      <span class="conversation-name">{{ conversation.name }}</span>
                      <div class="conversation-meta">
                        {{ icons.icon_info('icon-inline') }} {{ conversation._id|slice(0, 8) }}
                      </div>
                    </div>
                  {% else %}
                    <div class="conversation-avatar">
                      {{ icons.icon_users('icon-inline') }}
                    </div>
                    <div class="conversation-details">
                      {% if conversation.participants|length > 0 %}
                        <span class="conversation-name">
                          {% for p in conversation.participants %}
                            {{ p.displayName }}{% if not loop.last %} & {% endif %}
                          {% endfor %}
                        </span>
                      {% else %}
                        <span class="conversation-name">{{ 'Private Chat'|t }}</span>
                      {% endif %}
                      <div class="conversation-meta">
                        {{ icons.icon_info('icon-inline') }} {{ conversation._id|slice(0, 8) }}
                      </div>
                    </div>
                  {% endif %}
                </td>
                <td class="text-center">
                  {% if conversation.type == 'group' %}
                    <span class="badge badge-info">
                      {{ icons.icon_users('icon-inline') }} {{ 'Group'|t }}
                    </span>
                  {% else %}
                    <span class="badge badge-primary">
                      {{ icons.icon_users('icon-inline') }} {{ 'Private'|t }}
                    </span>
                  {% endif %}
                </td>
                <td class="participants-cell">
                  <div class="participants-list">
                    {% for participant in conversation.participants %}
                      <span class="participant-badge" title="Drupal ID: {{ participant.drupalId }}">
                        {{ icons.icon_user_circle('icon-inline') }} {{ participant.displayName }}
                      </span>
                    {% endfor %}
                  </div>
                </td>
                <td class="last-message-cell">
                  <small>
                    {% if conversation.lastMessage %}
                      {{ conversation.lastMessage|slice(0, 40) }}{% if conversation.lastMessage|length > 40 %}...{% endif %}
                    {% else %}
                      <span class="text-muted">{{ 'No messages'|t }}</span>
                    {% endif %}
                  </small>
                </td>
                <td class="text-center">
                  <span class="badge badge-secondary">
                    {{ icons.icon_users('icon-inline') }} {{ conversation.participantCount }}
                  </span>
                </td>
                <td class="text-center">
                  <span class="badge badge-success">
                    {{ icons.icon_mail('icon-inline') }} {{ conversation.messageCount }}
                  </span>
                </td>
                <td class="conversation-date">
                  {{ icons.icon_calendar('icon-inline') }}
                  {{ conversation.createdAt|date('M d, Y') }}
                  <div class="date-time">{{ conversation.createdAt|date('H:i') }}</div>
                </td>
                <td class="conversation-date">
                  {% if conversation.lastMessageAt %}
                    {{ icons.icon_clock('icon-inline') }}
                    {{ conversation.lastMessageAt|date('M d, Y') }}
                    <div class="date-time">{{ conversation.timeAgo }}</div>
                  {% else %}
                    <span class="text-muted">{{ 'No messages'|t }}</span>
                  {% endif %}
                </td>
                <td class="actions-cell">
                  <div class="action-buttons">
                    <a href="/admin/chat/conversations/{{ conversation._id }}" class="btn-action btn-view" title="{{ 'View Details'|t }}">
                      {{ icons.icon_eye('icon-inline') }}
                    </a>
                    <button class="btn-action btn-danger delete-conversation" data-id="{{ conversation._id }}" title="{{ 'Delete Conversation'|t }}" type="button">
                      {{ icons.icon_trash('icon-inline') }}
                    </button>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      
      {# Pagination #}
      {{ pager }}
      
    {% else %}
      <div class="empty-state">
        {{ icons.icon_message_square('icon-inline') }}
        <p>{{ 'No conversations found'|t }}</p>
        <small>{{ 'Conversations will appear here when users start chatting'|t }}</small>
      </div>
    {% endif %}

  </div>

</div>

{# 
  File: templates/chat-admin-users.html.twig
  Mô tả: Trang danh sách quản lý người dùng - Phiên bản chuyên nghiệp
  Kiến trúc:
    - SVG icon từ lucide-react
    - CSS tách biệt (không inline)
    - Dữ liệu thật từ backend Controller
    - AJAX cho block/unblock
    - Responsive design
#}

{# Import SVG icon macros #}
{% import '@chat_api/_icons.html.twig' as icons %}

{# Nạp CSS/JS thư viện chuyên nghiệp #}
{{ attach_library('chat_api/listing') }}

{% set css_import %}
  <link rel="stylesheet" href="/modules/custom/chat_api/css/listing.css">
  <link rel="stylesheet" href="/modules/custom/chat_api/css/notifications.css">
{% endset %}
{{ css_import|raw }}

<div class="chat-admin-users">
  
  {# ========== 1. HEADER ========== #}
  <div class="page-header">
    <div>
      <h1>
        {{ icons.icon_users('') }}
        {{ 'User Management'|t }}
      </h1>
      <p class="subtitle">{{ 'Manage and monitor all chat users'|t }}</p>
    </div>
    <div class="header-actions">
      <a href="/admin/chat" class="btn btn-secondary">
        {{ icons.icon_arrow_left('') }}
        {{ 'Back to Dashboard'|t }}
      </a>
    </div>
  </div>

  {# ========== 2. THỐNG KÊ (Statistics) ========== #}
  <div class="users-stats">
    
    {# Tổng User #}
    <div class="stat-box">
      <div class="stat-icon">
        {{ icons.icon_users('') }}
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.total_users }}</div>
        <div class="stat-label">{{ 'Total Users'|t }}</div>
      </div>
    </div>

    {# Active hôm nay #}
    <div class="stat-box stat-success">
      <div class="stat-icon">
        {{ icons.icon_check_circle('') }}
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.active_today }}</div>
        <div class="stat-label">{{ 'Online Today'|t }}</div>
      </div>
    </div>

    {# Active tuần này #}
    <div class="stat-box stat-warning">
      <div class="stat-icon">
        {{ icons.icon_clock('') }}
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.active_week }}</div>
        <div class="stat-label">{{ 'Online This Week'|t }}</div>
      </div>
    </div>

    {# Bị khóa #}
    <div class="stat-box stat-danger" data-stat-blocked>
      <div class="stat-icon">
        {{ icons.icon_ban('') }}
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ stats.blocked_users }}</div>
        <div class="stat-label">{{ 'Blocked'|t }}</div>
      </div>
    </div>
  </div>

  {# ========== 3. BẢNG DANH SÁCH ========== #}
  <div class="card">
    {% if users is not empty %}
      <div class="table-responsive">
        <table class="chat-table">
          <thead>
            <tr>
              <th>{{ 'Users'|t }}</th>
              <th>{{ 'Status'|t }}</th>
              <th>{{ 'Friends'|t }}</th>
              <th>{{ 'Friend Requests'|t }}</th>
              <th>{{ 'Registration'|t }}</th>
              <th>{{ 'Last Access'|t }}</th>
              <th class="text-right">{{ 'Actions'|t }}</th>
            </tr>
          </thead>
          <tbody>
            {% for user in users %}
              <tr data-user-uid="{{ user.uid }}" data-user-status="{% if user.status == 1 %}active{% else %}blocked{% endif %}" onclick="window.location.href='/admin/chat/users/{{ user.uid }}';" style="cursor: pointer;">
                
                {# Cột Thông tin User #}
                <td>
                  <div class="user-cell">
                    <div class="user-avatar">
                      {% if user.avatarUrl %}
                        <img src="{{ user.avatarUrl }}" alt="{{ user.name }}" />
                      {% else %}
                        <div>{{ user.name|first|upper }}</div>
                      {% endif %}
                    </div>
                    <div class="user-info">
                      <a href="/admin/chat/users/{{ user.uid }}" class="user-name">
                        {{ user.name }}
                      </a>
                      <div class="user-email">{{ user.mail }}</div>
                    </div>
                  </div>
                </td>
                
                {# Cột Trạng thái #}
                <td data-status-badge>
                  {% if user.status == 1 %}
                    <span class="badge badge-success">{{ 'Active'|t }}</span>
                  {% else %}
                    <span class="badge badge-danger">{{ 'Blocked'|t }}</span>
                  {% endif %}
                </td>
                
                {# Cột Bạn bè #}
                <td>
                  <div class="data-cell">
                    {{ icons.icon_user_friends('') }}
                    {{ user.friend_count }}
                  </div>
                </td>
                
                {# Cột Lời mời #}
                <td>
                  {% if user.pending_requests > 0 %}
                    <span class="badge badge-warning">{{ user.pending_requests }}</span>
                  {% else %}
                    <span class="text-muted">-</span>
                  {% endif %}
                </td>
                
                {# Cột Đăng ký #}
                <td>
                  <div class="data-cell">
                    {{ icons.icon_calendar('') }}
                    {{ user.days_registered }} {{ 'days ago'|t }}
                  </div>
                </td>
                
                {# Cột Truy cập cuối #}
                <td>
                  {% if user.days_since_access is not null %}
                    {% if user.days_since_access == 0 %}
                      <span class="text-success">{{ 'Today'|t }}</span>
                    {% else %}
                      {{ user.days_since_access }} {{ 'days ago'|t }}
                    {% endif %}
                  {% else %}
                    <span class="text-muted">{{ 'Never'|t }}</span>
                  {% endif %}
                </td>
                
                {# Cột Hành động #}
                <td class="text-right">
                  <div class="action-buttons">
                    {# Nút Xem chi tiết #}
                    <a href="/admin/chat/users/{{ user.uid }}" class="btn-icon" title="{{ 'View Details'|t }}">
                      {{ icons.icon_eye('') }}
                    </a>
                    
                    {# Nút Sửa thông tin #}
                    <a href="/admin/chat/users/{{ user.uid }}" class="btn-icon" title="{{ 'View Details'|t }}">
                      {{ icons.icon_edit('') }}
                    </a>
                    
                    {# Logic Nút Block/Unblock #}
                    {% if user.status == 1 %}
                      <button 
                        class="btn-icon btn-danger-icon" 
                        data-block-user="{{ user.uid }}"
                        title="{{ 'Block Account'|t }}"
                        type="button">
                        {{ icons.icon_ban('') }}
                      </button>
                    {% else %}
                      <button 
                        class="btn-icon btn-success-icon" 
                        data-unblock-user="{{ user.uid }}"
                        title="{{ 'Unblock'|t }}"
                        type="button">
                        {{ icons.icon_unlock('') }}
                      </button>
                    {% endif %}
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      {# PHÂN TRANG #}
      <div class="table-footer">
        <div class="table-info">
          {{ icons.icon_info('') }}
          {{ 'Showing'|t }} <strong>{{ users|length }}</strong> {{ 'users'|t }}
        </div>
        {{ pager }}
      </div>

    {% else %}
      {# EMPTY STATE #}
      <div class="empty-state">
        {{ icons.icon_users('') }}
        <h3>{{ 'No users found'|t }}</h3>
        <p>{{ 'There is currently no user data matching your request.'|t }}</p>
      </div>
    {% endif %}
  </div>
</div>

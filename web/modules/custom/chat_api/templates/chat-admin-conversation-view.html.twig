{#
/**
 * @file
 * Template for Conversation Detail View.
 *
 * Available variables:
 * - conversation: Conversation object from MongoDB
 * - messages: Array of message objects
 * - conversation_id: MongoDB conversation ID
 */
#}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="chat-admin-conversation-detail">
  {# Page Header #}
  <div class="page-header">
    <div class="header-left">
      <a href="/admin/chat/conversations" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> {{ 'Back to Conversations'|t }}
      </a>
      <h1>
        <i class="fas fa-comment-dots"></i>
        {% if conversation.type == 'group' %}
          {{ conversation.name }}
        {% else %}
          {{ 'Private Conversation'|t }}
        {% endif %}
      </h1>
    </div>
    <div class="header-actions">
      <button class="btn btn-danger" id="deleteConversationBtn" data-conversation-id="{{ conversation_id }}">
        <i class="fas fa-trash"></i> {{ 'Delete Conversation'|t }}
      </button>
    </div>
  </div>

  {# Conversation Info Card #}
  <div class="profile-section">
    <div class="profile-card">
      <div class="profile-avatar">
        <div class="avatar-circle">
          {% if conversation.type == 'group' %}
            <i class="fas fa-users"></i>
          {% else %}
            <i class="fas fa-user-friends"></i>
          {% endif %}
        </div>
      </div>
      <div class="profile-info">
        <h2>
          {% if conversation.type == 'group' %}
            {{ conversation.name }}
          {% else %}
            {{ 'Private Conversation'|t }}
          {% endif %}
        </h2>
        <p class="email">
          <i class="fas fa-hashtag"></i> {{ conversation._id|slice(0, 12) }}...
        </p>
        <div class="profile-badges">
          {% if conversation.type == 'group' %}
            <span class="badge badge-info">
              <i class="fas fa-users"></i> {{ 'Group Chat'|t }}
            </span>
          {% else %}
            <span class="badge badge-primary">
              <i class="fas fa-user-friends"></i> {{ 'Private Chat'|t }}
            </span>
          {% endif %}
        </div>
        <div class="profile-meta">
          <div class="meta-item">
            <i class="fas fa-calendar-plus"></i>
            <span>{{ 'Created:'|t }} {{ conversation.createdAt|date('M d, Y H:i') }}</span>
          </div>
          <div class="meta-item">
            <i class="fas fa-clock"></i>
            <span>{{ 'Last activity:'|t }} 
              {% if conversation.lastMessageAt %}
                {{ conversation.lastMessageAt|date('M d, Y H:i') }}
              {% else %}
                {{ 'Never'|t }}
              {% endif %}
            </span>
          </div>
          <div class="meta-item">
            <i class="fas fa-envelope"></i>
            <span>{{ 'Total messages:'|t }} {{ conversation.messageCount }}</span>
          </div>
          <div class="meta-item">
            <i class="fas fa-users"></i>
            <span>{{ 'Participants:'|t }} {{ conversation.participantCount }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  {# Statistics Grid #}
  <div class="stats-grid">
    <div class="stat-box">
      <div class="stat-icon">
        <i class="fas fa-envelope"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ conversation.messageCount }}</div>
        <div class="stat-label">{{ 'Total Messages'|t }}</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-icon">
        <i class="fas fa-users"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ conversation.participantCount }}</div>
        <div class="stat-label">{{ 'Participants'|t }}</div>
      </div>
    </div>
    <div class="stat-box">
      <div class="stat-icon">
        <i class="fas fa-comments"></i>
      </div>
      <div class="stat-content">
        <div class="stat-value">{{ messages|length }}</div>
        <div class="stat-label">{{ 'Recent Messages'|t }}</div>
      </div>
    </div>
  </div>

  {# Participants List #}
  <div class="content-wrapper">
    <div class="section-card">
      <div class="section-header">
        <h3>
          <i class="fas fa-users"></i>
          {{ 'Participants'|t }} ({{ conversation.participantCount }})
        </h3>
      </div>
      <div class="section-content">
        {% if conversation.participants|length > 0 %}
          <div class="friends-list">
            {% for participant in conversation.participants %}
              <div class="friend-item">
                <div class="friend-avatar">
                  {% if participant.avatarUrl %}
                    <img src="{{ participant.avatarUrl }}" alt="{{ participant.displayName }}">
                  {% else %}
                    {{ participant.displayName|first|upper }}
                  {% endif %}
                </div>
                <div class="friend-info">
                  <div class="friend-name">{{ participant.displayName }}</div>
                  <div class="friend-meta">
                    <i class="fas fa-envelope"></i> {{ participant.email }}
                    {% if participant.drupalId %}
                      <div>
                        <i class="fas fa-id-card"></i> {{ 'Drupal ID:'|t }} {{ participant.drupalId }}
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="empty-state">
            <i class="fas fa-users"></i>
            <p>{{ 'No participants found'|t }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {# Recent Messages #}
  <div class="content-wrapper">
    <div class="section-card">
      <div class="section-header">
        <h3>
          <i class="fas fa-comments"></i>
          {{ 'Recent Messages'|t }} ({{ messages|length }})
        </h3>
        <div class="section-info">
          {{ 'Showing latest 50 messages'|t }}
        </div>
      </div>
      <div class="section-content">
        {% if messages|length > 0 %}
          <div class="messages-list">
            {% for message in messages %}
              <div class="message-item">
                <div class="message-avatar">
                  {% if message.senderId.avatarUrl %}
                    <img src="{{ message.senderId.avatarUrl }}" alt="{{ message.senderId.displayName }}">
                  {% else %}
                    {{ message.senderId.displayName|first|upper }}
                  {% endif %}
                </div>
                <div class="message-content">
                  <div class="message-header">
                    <strong>{{ message.senderId.displayName }}</strong>
                    <span class="message-time">
                      <i class="fas fa-clock"></i> {{ message.createdAt|date('M d, Y H:i:s') }}
                    </span>
                  </div>
                  <div class="message-body">
                    {{ message.content|truncate(500) }}
                  </div>
                  {% if message.attachments|length > 0 %}
                    <div class="message-attachments">
                      <i class="fas fa-paperclip"></i>
                      {% for attachment in message.attachments %}
                        <span class="attachment-badge">{{ attachment.filename|default('Attachment') }}</span>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>{{ 'No messages in this conversation'|t }}</p>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

</div>

<style>
  .chat-admin-conversation-detail {
    max-width: 1200px;
    margin: 0 auto;
  }

  .messages-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-height: 600px;
    overflow-y: auto;
    padding: 15px 0;
    border-top: 1px solid #e0e0e0;
  }

  .message-item {
    display: flex;
    gap: 12px;
    padding: 12px;
    background: #f8f9fa;
    border-radius: 8px;
    transition: background-color 0.2s;
  }

  .message-item:hover {
    background: #f0f1f2;
  }

  .message-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: bold;
    font-size: 14px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .message-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .message-content {
    flex: 1;
    min-width: 0;
  }

  .message-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
    gap: 12px;
  }

  .message-header strong {
    font-size: 14px;
    color: #333;
  }

  .message-time {
    font-size: 12px;
    color: #999;
    white-space: nowrap;
  }

  .message-body {
    font-size: 13px;
    color: #555;
    line-height: 1.5;
    word-break: break-word;
    white-space: pre-wrap;
  }

  .message-attachments {
    margin-top: 8px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .attachment-badge {
    display: inline-block;
    padding: 4px 8px;
    background: #e3f2fd;
    color: #1976d2;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
  }

  .section-info {
    font-size: 12px;
    color: #999;
    font-style: italic;
  }
</style>

<script>
(function() {
  const deleteBtn = document.getElementById('deleteConversationBtn');
  if (deleteBtn) {
    deleteBtn.addEventListener('click', function() {
      const conversationId = this.getAttribute('data-conversation-id');
      if (confirm('{{ "Are you sure you want to delete this conversation? This action cannot be undone."|t }}')) {
        // Fetch delete API
        fetch('/api/conversations/admin/' + conversationId, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
          },
        })
        .then(response => response.json())
        .then(data => {
          if (data.success) {
            alert('{{ "Conversation deleted successfully!"|t }}');
            window.location.href = '/admin/chat/conversations';
          } else {
            alert('{{ "Failed to delete conversation: "|t }}' + (data.message || 'Unknown error'));
          }
        })
        .catch(error => {
          alert('{{ "Error deleting conversation: "|t }}' + error.message);
        });
      }
    });
  }
})();
</script>

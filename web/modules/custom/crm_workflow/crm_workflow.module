/**
 * Custom validation for deal form.
 */
function _crm_workflow_validate_deal_won(array &$form, FormStateInterface $form_state) {
  $stage = $form_state->getValue(['field_stage', 0, 'target_id']);
  
  if (!$stage) {
    return;
  }
  
  $stage_term = \Drupal\taxonomy\Entity\Term::load($stage);
  
  if ($stage_term && $stage_term->getName() === 'Won') {
    // Check if contract file is uploaded
    $contract_file = $form_state->getValue(['field_contract_file', 0, 'target_id']);
    
    if (empty($contract_file)) {
      $form_state->setErrorByName('field_contract_file', t('You must upload a contract file before marking this Deal as Won!'));
    }
  }
}

/**
 * Implements hook_help().
 */
function crm_workflow_help($route_name, $route_match) {
  switch ($route_name) {
    case 'help.page.crm_workflow':
      $output = '<h3>' . t('About') . '</h3>';
      $output .= '<p>' . t('CRM Workflow Automation module provides automated workflows for Open CRM system.') . '</p>';
      $output .= '<h3>' . t('Features') . '</h3>';
      $output .= '<ul>';
      $output .= '<li>' . t('Deal Won validation (require contract file upload)') . '</li>';
      $output .= '<li>' . t('Email notifications to managers when deal is won') . '</li>';
      $output .= '<li>' . t('Activity logging automation') . '</li>';
      $output .= '</ul>';
      return $output;
  }
}

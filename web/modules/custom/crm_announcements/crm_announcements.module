<?php

use Drupal\Core\Url;

/**
 * Implements hook_toolbar().
 */
function crm_announcements_toolbar() {
  $items = [];

  $items['crm_announcements'] = [
    '#type' => 'toolbar_item',
    'tab' => [
      '#type' => 'link',
      '#title' => t('Internal Announcements'),
      '#url' => Url::fromRoute('crm_announcements.feed'),
      '#attributes' => [
        'title' => t('Internal Announcements'),
        'class' => ['toolbar-icon', 'toolbar-icon-crm-announcements', 'use-ajax'],
        'data-dialog-type' => 'dialog',
        'data-dialog-renderer' => 'off_canvas',
        'data-dialog-options' => json_encode(['width' => 450]),
      ],
      '#attached' => [
        'library' => [
          'core/drupal.dialog.ajax',
          'crm_announcements/crm_announcements.toolbar',
        ],
      ],
    ],
    '#weight' => 3390,
  ];

  return $items;
}

/**
 * Implements hook_form_BASE_FORM_ID_alter() for node_form.
 */
function crm_announcements_form_node_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  $form_object = $form_state->getFormObject();
  if (!$form_object || !method_exists($form_object, 'getEntity')) {
    return;
  }

  $node = $form_object->getEntity();
  if (!$node instanceof \Drupal\node\NodeInterface || $node->bundle() !== 'crm_announcement') {
    return;
  }

  $form['#attached']['library'][] = 'crm_announcements/crm_announcements.node_form';
  
  // Wrap the entire form in a modern container
  $form['#attributes']['class'][] = 'crm-announcement-node-form';
  $form['#attributes']['class'][] = 'crm-announcement-modal-content';
  
  // Header
  $form['crm_announcement_header'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['crm-form-header-gradient']],
    '#weight' => -100,
    'icon' => [
      '#markup' => '<div class="crm-form-header-icon"><i data-lucide="megaphone"></i></div>',
    ],
    'title_group' => [
      '#type' => 'container',
      '#attributes' => ['class' => ['crm-form-header-text']],
      'title' => [
        '#markup' => '<h2 class="crm-form-header-title">' . t('Internal Announcement') . '</h2>',
      ],
      'desc' => [
        '#markup' => '<div class="crm-form-header-desc">' . t('Broadcast a new message to the CRM team.') . '</div>',
      ],
    ],
  ];

  // Group fields into cards for consistent spacing
  foreach (['title', 'field_announcement_level', 'body', 'field_announcement_target'] as $field_name) {
    if (isset($form[$field_name])) {
      $form[$field_name]['#prefix'] = '<div class="crm-form-field-card">';
      $form[$field_name]['#suffix'] = '</div>';
    }
  }

  // Footer styling
  if (isset($form['actions'])) {
    $form['actions']['#attributes']['class'][] = 'crm-form-footer';
    
    // Remove redundant buttons for a cleaner modal look
    foreach (['preview', 'delete', 'cancel'] as $key) {
      if (isset($form['actions'][$key])) {
        $form['actions'][$key]['#access'] = FALSE;
      }
    }

    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['class'][] = 'button--crm-save';
      $form['actions']['submit']['#value'] = t('Save Announcement');
      // Wrap the buttons for right alignment
      $form['actions']['submit']['#prefix'] = '<div class="crm-footer-actions-right">';
      $form['actions']['submit']['#suffix'] = '</div>';
    }
    
  }

  // Use after_build to ensure our changes are not overridden by themes (like Gin)
  $form['#after_build'][] = 'crm_announcements_node_form_after_build';
}

/**
 * After build callback to ensure certain elements stay hidden.
 */
function crm_announcements_node_form_after_build($form, &$form_state) {
  if (isset($form['actions']['cancel'])) {
    $form['actions']['cancel']['#access'] = FALSE;
  }
  return $form;
}
  // All icons and AJAX dependencies are now in crm_announcements.node_form

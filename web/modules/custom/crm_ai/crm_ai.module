<?php

/**
 * @file
 * CRM AI AutoComplete module.
 */

use Drupal\Core\Form\FormStateInterface;

/**
 * Implements hook_form_alter().
 *
 * Adds AI Complete button to entity forms.
 */
function crm_ai_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  // Check if AI autocomplete is enabled.
  if (!\Drupal::moduleHandler()->moduleExists('crm_ai')) {
    return;
  }

  // Add AI button to contact, deal, organization forms.
  $supported_forms = [
    'node_contact_form',
    'node_contact_edit_form',
    'node_deal_form',
    'node_deal_edit_form',
    'node_organization_form',
    'node_organization_edit_form',
    'node_activity_form',
    'node_activity_edit_form',
  ];

  if (!in_array($form_id, $supported_forms)) {
    return;
  }

  // Check permission.
  $account = \Drupal::currentUser();
  if (!$account->hasPermission('use crm ai autocomplete')) {
    return;
  }

  // Attach library.
  $form['#attached']['library'][] = 'crm_ai/ai-autocomplete';

  // Add AI Complete button to form actions.
  if (!isset($form['actions'])) {
    $form['actions'] = ['#type' => 'actions'];
  }

  $form['actions']['ai_complete'] = [
    '#type' => 'button',
    '#value' => '✨ ' . t('Generate with AI'),
    '#name' => 'ai_complete_button',
    '#attributes' => [
      'class' => ['btn-ai-complete', 'button', 'button--primary'],
      'data-form-id' => $form_id,
    ],
    '#submit' => [],
    '#weight' => -5,
  ];

  // Add Drupal behaviors to handle button clicks.
  $form['#attached']['drupalSettings']['crm_ai'] = [
    'endpoint' => '/api/crm/ai/autocomplete',
    'enabledEntities' => \Drupal::config('crm_ai.settings')->get('enabled_entities') ?? ['contact', 'deal', 'organization'],
  ];
}

/**
 * Implements hook_library_info_alter().
 */
function crm_ai_library_info_alter(&$libraries, $extension) {
  // Allow modules to extend AI libraries if needed.
}

/**
 * Implements hook_page_attachments().
 */
function crm_ai_page_attachments(array &$attachments) {
  // Attach AI library globally if needed.
  if (\Drupal::currentUser()->hasPermission('use crm ai autocomplete')) {
    // Optional: Attach globally on specific pages.
  }
}

{#
  Template: quickadd-deal-form.html.twig
  Uses the same HTML structure as the inline-edit add modal (add-modal-deal)
#}
<div class="quickadd-modal-wrapper">
  <div class="crm-modal-container add-modal add-modal-deal">

    <div class="crm-modal-header add-modal-header">
      <div class="add-modal-header-icon">
        <i data-lucide="briefcase"></i>
      </div>
      <div class="add-modal-header-text">
        <h2>New Deal</h2>
        <p class="add-modal-subtitle">Create a new sales opportunity</p>
      </div>
      <button class="crm-modal-close" type="button" onclick="window.history.back()" aria-label="Close">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="quickadd-deal-form" class="crm-modal-form add-form" data-type="deal">
      <div class="crm-modal-body">

        <div class="form-field required-field">
          <label class="required">Deal Name<span class="required-mark"></span></label>
          <input type="text" id="deal-title" name="title" required
                 placeholder="Deal with ABC Company" autocomplete="off">
        </div>

        <div class="form-field required-field">
          <label class="required">Deal Value (VND)<span class="required-mark"></span></label>
          <input type="number" id="deal-amount" name="amount" required
                 step="1000" placeholder="50000000" min="0">
        </div>

        <div class="form-field">
          <label>Pipeline Stage</label>
          <select id="deal-stage" name="stage">
            {{ stage_options|raw }}
          </select>
        </div>

        <div class="form-field required-field">
          <label class="required">Primary Contact<span class="required-mark"></span></label>
          <select id="deal-contact" name="contact" required>
            {{ contact_options|raw }}
          </select>
        </div>

        <div class="form-field">
          <label>Expected Close Date</label>
          <input type="date" id="deal-closing-date" name="closing_date">
        </div>

      </div>{# /.crm-modal-body #}

      <div class="crm-modal-footer add-modal-footer">
        <span class="required-hint"><span class="required-mark"></span> Required fields</span>
        <div class="add-modal-footer-actions">
          <div class="save-status" id="quickadd-message"></div>
          <button type="button" class="btn-cancel" onclick="window.history.back()">
            <i data-lucide="x"></i><span>Cancel</span>
          </button>
          <button type="submit" form="quickadd-deal-form" class="btn-save save-btn qa-deal-submit">
            <i data-lucide="sparkles"></i><span>Save Deal</span>
          </button>
        </div>
      </div>

    </form>

  </div>
</div>
</div>

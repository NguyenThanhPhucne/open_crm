<div class="quickadd-modal-wrapper">
  <div class="quickadd-form-container">
    <div class="quickadd-header">
      <h2>
        <i data-lucide="briefcase"></i>
        Thêm cơ hội nhanh
      </h2>
      <button class="quickadd-close" onclick="window.history.back()">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="quickadd-deal-form" class="quickadd-form">
      <div class="form-row">
        <div class="form-group full-width">
          <label for="deal-title" class="required">Tên cơ hội</label>
          <input type="text" id="deal-title" name="title" required placeholder="Deal với Công ty ABC">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="deal-amount" class="required">Giá trị (VNĐ)</label>
          <input type="number" id="deal-amount" name="amount" required step="1000" placeholder="1000000">
        </div>
        <div class="form-group">
          <label for="deal-stage">Giai đoạn</label>
          <select id="deal-stage" name="stage" required>
            {{ stage_options|raw }}
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="deal-contact">Khách hàng</label>
          <select id="deal-contact" name="contact">
            {{ contact_options|raw }}
          </select>
        </div>
        <div class="form-group">
          <label for="deal-closing-date">Ngày dự kiến chốt</label>
          <input type="date" id="deal-closing-date" name="closing_date">
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="window.history.back()">Hủy</button>
        <button type="submit" class="btn-primary">
          <i data-lucide="save"></i>
          Lưu cơ hội
        </button>
      </div>

      <div id="quickadd-message" class="alert" style="display:none;"></div>
    </form>
  </div>
</div>

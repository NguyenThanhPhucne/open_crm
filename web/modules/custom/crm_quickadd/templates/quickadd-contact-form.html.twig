{#
  Template: quickadd-contact-form.html.twig
  Uses the same HTML structure as the inline-edit add modal (add-modal-contact)
#}
<div class="quickadd-modal-wrapper">
  <div class="crm-modal-container add-modal add-modal-contact">

    <div class="crm-modal-header add-modal-header">
      <div class="add-modal-header-icon">
        <i data-lucide="user-plus"></i>
      </div>
      <div class="add-modal-header-text">
        <h2>New Contact</h2>
        <p class="add-modal-subtitle">Add a contact to your CRM</p>
      </div>
      <button class="crm-modal-close" type="button" onclick="window.history.back()" aria-label="Close">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="quickadd-contact-form" class="crm-modal-form add-form" data-type="contact">
      <div class="crm-modal-body">

        <div class="form-field required-field">
          <label class="required">Full Name<span class="required-mark">*</span></label>
          <input type="text" id="contact-name" name="name" required
                 placeholder="e.g. Nguyễn Văn An" autocomplete="off">
        </div>

        <div class="form-field required-field">
          <label class="required">Phone Number<span class="required-mark">*</span></label>
          <input type="tel" id="contact-phone" name="phone" required
                 placeholder="+84 901 234 567">
          <span class="field-error" id="phone-validation" style="display:none;"></span>
        </div>

        <div class="form-field">
          <label>Email Address</label>
          <input type="email" id="contact-email" name="email"
                 placeholder="name@company.com">
          <span class="field-error" id="email-validation" style="display:none;"></span>
        </div>

        <div class="form-field">
          <label>Job Title</label>
          <input type="text" id="contact-position" name="position"
                 placeholder="Sales Manager">
        </div>

        <div class="form-field">
          <label>Customer Type</label>
          <select id="contact-customer-type" name="customer_type">
            {{ type_options|raw }}
          </select>
        </div>

        <div class="form-field">
          <label>Lead Source</label>
          <select id="contact-source" name="source">
            {{ source_options|raw }}
          </select>
        </div>

        <div class="form-field">
          <label>Company</label>
          <select id="contact-organization" name="organization">
            {{ org_options|raw }}
          </select>
        </div>

        {# Inline new company creation #}
        <div id="inline-org-fields" style="display:none;">
          <div class="form-field required-field">
            <label class="required">New Company Name<span class="required-mark">*</span></label>
            <input type="text" id="inline-org-name" name="organization_name"
                   placeholder="ABC Company Ltd.">
          </div>
        </div>

      </div>{# /.crm-modal-body #}

      <div class="crm-modal-footer add-modal-footer">
        <span class="required-hint"><span class="required-mark">*</span> Required fields</span>
        <div class="add-modal-footer-actions">
          <div class="save-status" id="quickadd-message"></div>
          <button type="button" class="btn-cancel" onclick="window.history.back()">
            <i data-lucide="x"></i><span>Cancel</span>
          </button>
          <button type="submit" form="quickadd-contact-form" class="btn-save save-btn qa-contact-submit">
            <i data-lucide="user-check"></i><span>Save Contact</span>
          </button>
        </div>
      </div>

    </form>

  </div>
</div>

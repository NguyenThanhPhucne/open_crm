{#
  Template: quickadd-organization-form.html.twig
  Uses the same HTML structure as the inline-edit add modal (add-modal-organization)
#}
<div class="quickadd-modal-wrapper">
  <div class="crm-modal-container add-modal add-modal-organization">

    <div class="crm-modal-header add-modal-header">
      <div class="add-modal-header-icon">
        <i data-lucide="building-2"></i>
      </div>
      <div class="add-modal-header-text">
        <h2>New Organization</h2>
        <p class="add-modal-subtitle">Add a new company or organization</p>
      </div>
      <button class="crm-modal-close" type="button" onclick="window.history.back()" aria-label="Close">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="quickadd-organization-form" class="crm-modal-form add-form" data-type="organization">
      <div class="crm-modal-body">

        <div class="form-field required-field">
          <label class="required">Company Name<span class="required-mark">*</span></label>
          <input type="text" id="org-name" name="name" required
                 placeholder="ABC Corporation Ltd." autocomplete="off">
        </div>

        <div class="form-field">
          <label>Website</label>
          <input type="url" id="org-website" name="website"
                 placeholder="https://example.com">
        </div>

        <div class="form-field">
          <label>Industry</label>
          <select id="org-industry" name="industry">
            {{ industry_options|raw }}
          </select>
        </div>

        <div class="form-field">
          <label>Address</label>
          <input type="text" id="org-address" name="address"
                 placeholder="123 Main St, City">
        </div>

      </div>{# /.crm-modal-body #}

      <div class="crm-modal-footer add-modal-footer">
        <span class="required-hint"><span class="required-mark">*</span> Required fields</span>
        <div class="add-modal-footer-actions">
          <div class="save-status" id="quickadd-message"></div>
          <button type="button" class="btn-cancel" onclick="window.history.back()">
            <i data-lucide="x"></i><span>Cancel</span>
          </button>
          <button type="submit" form="quickadd-organization-form" class="btn-save save-btn qa-org-submit">
            <i data-lucide="building-2"></i><span>Save Organization</span>
          </button>
        </div>
      </div>

    </form>

  </div>
</div>

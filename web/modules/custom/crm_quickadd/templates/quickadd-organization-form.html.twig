<div class="quickadd-modal-wrapper">
  <div class="quickadd-form-container">
    <div class="quickadd-header">
      <h2>
        <i data-lucide="building-2"></i>
        Quick Add Organization
      </h2>
      <button class="quickadd-close" onclick="window.history.back()">
        <i data-lucide="x"></i>
      </button>
    </div>

    <form id="quickadd-organization-form" class="quickadd-form">
      <div class="form-row">
        <div class="form-group full-width">
          <label for="org-name" class="required">Company Name</label>
          <input type="text" id="org-name" name="name" required placeholder="ABC Ltd.">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="org-website">Website</label>
          <input type="url" id="org-website" name="website" placeholder="https://example.com">
        </div>
        <div class="form-group">
          <label for="org-industry">Industry</label>
          <select id="org-industry" name="industry">
            {{ industry_options|raw }}
          </select>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group full-width">
          <label for="org-address">Address</label>
          <input type="text" id="org-address" name="address" placeholder="123 Main St, City, Country">
        </div>
      </div>

      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="window.history.back()">Cancel</button>
        <button type="submit" class="btn-primary">
          <i data-lucide="save"></i>
          Save Organization
        </button>
      </div>

      <div id="quickadd-message" class="alert" style="display:none;"></div>
    </form>
  </div>
</div>

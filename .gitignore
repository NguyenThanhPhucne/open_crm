# ============================================
# Drupal CRM Project - .gitignore
# ============================================

# ========== Composer Dependencies ==========
/vendor/
!composer.json
!composer.lock

# ========== Drupal Core (installed via Composer) ==========
/web/core/
/web/.csslintrc
/web/.editorconfig
/web/.eslintignore
/web/.eslintrc.json
/web/.ht.router.php
/web/.htaccess
/web/autoload.php
/web/index.php
/web/INSTALL.txt
/web/README.md
/web/robots.txt
/web/update.php
/web/web.config
/web/example.gitignore

# ========== Contributed Modules & Themes ==========
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# ========== Custom Code (ALWAYS COMMIT) ==========
!/web/modules/custom/
!/web/modules/custom/**
!/web/themes/custom/
!/web/themes/custom/**
!/web/profiles/custom/
!/web/profiles/custom/**

# ========== Configuration (ALWAYS COMMIT) ==========
!/config/
!/config/**

# ========== Settings & Credentials (NEVER COMMIT) ==========
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/*/services.yml
!/web/sites/*/default.settings.php

# ========== User Uploaded Files ==========
/web/sites/*/files/
/web/sites/*/private/
!/web/sites/default/files/.htaccess

# ========== Cache & Generated Files ==========
/web/sites/simpletest/

# ========== Scripts (COMMIT ALL) ==========
!/scripts/
!/scripts/**

# ========== Fixtures & Recipes (COMMIT) ==========
!/fixtures/
!/fixtures/**
!/recipes/
!/recipes/**

# ========== DDEV Config (COMMIT) ==========
# Keep full DDEV config for reproducible environment
!.ddev/
!.ddev/**
# Ignore DDEV internal generated files only
.ddev/.dbimageBuild/
.ddev/.webimageBuild/
.ddev/.ddev-docker-compose-base.yaml
.ddev/.ddev-docker-compose-full.yaml
.ddev/mutagen/.start-synced

# ========== Database Files (NEVER COMMIT) ==========
*.sql
*.sql.gz
!db/latest.sql.gz
*.mysql
*.dump
*.sqlite
*.db
/backups/
/database/

# ========== Logs ==========
*.log
/logs/
/log/
/web/sites/*/logs/

# ========== IDE & Editor Files ==========
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace
nbproject/
.project
.buildpath
.settings/

# ========== OS Files ==========
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
.directory
.fuse_hidden*

# ========== Node.js ==========
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock
/.pnp/
.pnp.js
/build/
/dist/

# ========== Testing ==========
/phpunit.xml
/behat.yml
/.phpunit.result.cache

# ========== Temporary Files ==========
*.swp
*.swo
*~
*.tmp
/tmp/
/temp/

# ========== One-off Debug/Test Scripts at root ==========
# (Keep scripts/ folder but ignore root-level throwaway scripts)
/test*.php
/debug*.php
/verify*.php
/check*.php
/analyze*.php
/audit*.php
/validate*.php
/fix_*.php

# ========== Backup & Generated Artifacts ==========
*.bak
*.backup
*.orig
.gitignore.old
web/sites/*/php/

# ========== PHP Code Style Cache ==========
*.php_cs.cache
.php_cs.cache
.php-cs-fixer.cache

# ========== Docker ==========
docker-compose.override.yml
.docker/
.vagrant/
Vagrantfile.local
!README.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!/web/INSTALL.txt
!/web/README.md

# ========== Core Test Fixtures (Keep) ==========
# Don't ignore core test fixtures
!/web/core/modules/system/tests/fixtures/**

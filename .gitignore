# ============================================
# Drupal CRM Project - .gitignore
# ============================================
# Only commit custom code and essential config
# Exclude vendor, core, contrib, and generated files
# ============================================

# ========== Composer Dependencies ==========
/vendor/

# Keep composer files to rebuild dependencies
!composer.json
!composer.lock

# ========== Drupal Core ==========
# Drupal core is installed via Composer
/web/core/
/web/.csslintrc
/web/.editorconfig
/web/.eslintignore
/web/.eslintrc.json
/web/.ht.router.php
/web/.htaccess
/web/autoload.php
/web/index.php
/web/INSTALL.txt
/web/README.md
/web/robots.txt
/web/update.php
/web/web.config
/web/example.gitignore

# ========== Contributed Modules & Themes ==========
# Install from composer - don't commit
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# ========== Custom Code (COMMIT THESE!) ==========
# Custom modules - KEEP
!/web/modules/custom/
!/web/modules/custom/**

# Custom themes - KEEP
!/web/themes/custom/
!/web/themes/custom/**

# Custom profiles - KEEP if exists
!/web/profiles/custom/
!/web/profiles/custom/**

# ========== Configuration (COMMIT!) ==========
# Config directory - KEEP ALL YML FILES
!/config/
!/config/**/*.yml

# ========== Settings & Credentials ==========
# Ignore settings files (contain DB credentials)
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/*/services*.yml

# Keep default settings template
!/web/sites/*/default.settings.php

# ========== User Uploaded Files ==========
# Ignore all uploaded files
/web/sites/*/files/
/web/sites/*/private/

# Exception: Keep directory structure with .htaccess
!/web/sites/default/files/.htaccess

# ========== Cache & Generated Files ==========
/web/sites/*/files/css/
/web/sites/*/files/js/
/web/sites/*/files/php/
/web/sites/*/files/styles/
/web/sites/*/files/languages/
/web/sites/simpletest/

# ========== Scripts ==========
# Keep essential scripts
!/scripts/
!/scripts/**

# Ignore generated/test scripts
scripts/*test*.php
scripts/*test*.sh
scripts/*debug*.php
scripts/*audit*.php
scripts/*check*.php
scripts/*fix*.php
scripts/*fix*.sh

# ========== Fixtures & Sample Data (KEEP) ==========
!/fixtures/
!/fixtures/**/*.yml
!/fixtures/**/*.php

# ========== Recipes (KEEP) ==========
!/recipes/
!/recipes/**

# ========== Documentation ==========
# Keep essential docs
!README.md
!LICENSE.txt
!COMPLETE_GUIDE.md
!CONTENT_TYPES.md
!FEATURES_GUIDE.md
!TEAM_PERMISSIONS_GUIDE.md
!PRODUCTION_READINESS.md
!DATA_IMPORT_GUIDE.md
!DATA_STORAGE_EXPLANATION.md
!CUSTOM_MODULES_API_DOCS.md

# Keep docs folder
!/docs/
!/docs/**/*.md

# ========== IDE & Editor Files ==========
# PhpStorm / IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# NetBeans
nbproject/

# Eclipse
.project
.buildpath
.settings/

# Vim
*.swp
*.swo
*~

# ========== OS Files ==========
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.fuse_hidden*

# ========== Development Tools ==========
# DDEV - keep main config
.ddev/
!.ddev/config.yaml
!.ddev/config.*.yaml

# Docker
docker-compose.override.yml
.docker/

# Node.js (if frontend build exists)
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock
/.pnp/
.pnp.js
/build/
/dist/

# ========== Database Files ==========
*.sql
*.sql.gz
*.mysql
*.dump
*.sqlite
*.db
/backups/
/database/

# ========== Logs ==========
*.log
/logs/
/log/
/web/sites/*/logs/

# ========== Testing ==========
/tests/
/phpunit.xml
/behat.yml
/.phpunit.result.cache

# ========== Other Tools ==========
# Drush
/.drush/
/drush/contrib/
/drush/Commands/

# Drupal Console
/.console/
/.drupal-console/

# DrupalVM
.vagrant/
Vagrantfile.local

# ========== Temporary & Backup Files ==========
*.bak
*.swp
*~
*.orig
*.tmp
/tmp/
/temp/

# Test HTML files
*.test.html
test-*.html
*-test.html

# Sample data CSVs
sample_*.csv

# Backup gitignore
.gitignore.old

# ========== Core Test Fixtures (Keep) ==========
# Don't ignore core test fixtures
!/web/core/modules/system/tests/fixtures/**
